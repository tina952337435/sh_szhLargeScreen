import requestWX from "@/utils/requestWX";
const serveName = ''
export default {
  //雷达图、降雨预报图等
  GetTyphoonWeacontent: (params) => {
    var TOKEN="768ADC6A9E72BFEE4891F1F98650FEEE";
    params.PARAMETER.TOKEN=TOKEN;
    var postParam={
      "METHOD": params.METHOD,
      "KEYID": "admin",
      "PLATFORMIP": "平台",
      "PARAMETER": JSON.stringify(params.PARAMETER)
    }
    return requestWX.post(`${serveName}`, postParam);
  }
}
