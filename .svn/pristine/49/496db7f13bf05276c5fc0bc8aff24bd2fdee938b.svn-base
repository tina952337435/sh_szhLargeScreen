		var valueHJHQ = Number(data[num]["1744830552"]);//杭嘉湖区
		var value = ((valueTH + valueYCDMQ + valueHJHQ) / 3).toFixed(1);

		result.push({ tm: tm, drp: value, tmShort: tmShort });
		drpDay += Number(value);
		if ((num % 24 == 0 && num > 0) || num == dataResult.length - 1) {
			var tmDay = dayjs(new Date(dataResult[_day * 24].TM)).format("MM-DD");
			tmShort = tmDay;
			resultDay.push({ tm: tmDay, drp: drpDay, tmShort: tmShort });
			drpDay = 0;
			_day++;
		}
	}
	const strNote = [];
	strNote.push({ name: "时间", codename: "tmShort", tableV: "0", isShow: true });
