function JsonColumnChart(strJson) {
	var dataResult = strJson;
	var result = [], resultDay = [];
	var drpDay = 0;
	var _day = 0;
	for (var num = 0; num < dataResult.length; num++) {
		var tm = dayjs(new Date(dataResult[num].TM)).format("YYYY-MM-DD HH:mm:ss");
		var tmShort = dayjs(tm).format("MM-DD");
		// console.error('tm',tm);
		var valueTH = Number(dataResult[num]["1744830562"]);
