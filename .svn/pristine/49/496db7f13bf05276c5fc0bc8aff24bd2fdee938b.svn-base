		wcxyq += Number(data[num]["1744830544"]);
		pdq += Number(data[num]["1744830546"]);
		hjhq += Number(data[num]["1744830552"]);
		thq += Number(data[num]["1744830562"]);

		var tm = dayjs(new Date(data[num].TM)).format("YYYY-MM-DD HH:mm:ss");
		var tmShort = dayjs(tm).format("MM-DD");
		// console.error('tm',tm);
		var valueTH = Number(data[num]["1744830562"]);//太湖区
		var valueYCDMQ = Number(data[num]["1744830533"]);//阳澄淀泖区
		var valueHJHQ = Number(data[num]["1744830552"]);//杭嘉湖区
		var value = ((valueTH + valueYCDMQ + valueHJHQ) / 3).toFixed(1);
		result.push({ tm: tm, drp: value, tmShort: tmShort });
	}
