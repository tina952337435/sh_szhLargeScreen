//根据降雨值分颜色
//根据降雨值分颜色
function getRainColor(value) {
	value = Number(value);
	var color = "rgba(10,18,51,0)";
	var txtColor = "#ffffff";
	// color = "#efefef";
	txtColor = "#000000";
	if (value > 0 && value < 10) {
		color = "#A7F387";
		txtColor = "#000000";
	}
	else if (value >= 10 && value < 25) {
		color = "#39BC39";
		txtColor = "#000000";
	}
	else if (value >= 25 && value < 50) {
		color = "#62B7FE";
		txtColor = "#ffffff";
	}
	else if (value >= 50 && value < 100) {
		color = "#0004F6";
		txtColor = "#ffffff";
	}
	else if (value >= 100 && value < 250) {
		color = "#F801FA";
	}
	else if (value >= 250) {
		color = "#800140";
	}

	
	// console.error(value,color + "@" + txtColor);
	return color + "@" + txtColor;
}

//面平均降雨计算
function CalculatedareaPjjy(hx, hjh, wcxy, pdpx, ycdm, th, zx) {
	var mianji = 35969.86;
	var hxq = 7269.35;
	var wcxyq = 3698.91;
	var ycdmq = 4425.32;
	var pdq = 4162.06;
	var hjhq = 7275.69;
	var zxq = 5945.29;
	var thq = 3193.24;
	var mDRP = Number((hx * hxq + hjh * hjhq + wcxy * wcxyq + pdpx * pdq + ycdm * ycdmq + th * thq + zx * zxq) / mianji).toFixed(1);
	return mDRP;
}

function fangda() {
