<template>
  <div style="width: calc(100% - 40px); float: left; margin-left: 20px;margin-top: 20px;" id="divGCJK">
    <div id="GCJK" @click="handleClick">
    </div>
  </div>

  <MyDialog :showDialog="showDialog" @close="showDialog = false" :title="titleName" :typeExkey="typeExkey"
    :typeEqptp="typeEqptp" style="width: 70%; height: 700px">
    <GQLine />
  </MyDialog>
</template>
<script setup>
import '@/assets/styles/danzhanGQVIEWNew.css';
import MyDialog from "@/components/ComDialog.vue";
import GQLine from "@/components/danzhan/gq/GQLine.vue";
import api from "@/api/zonglan/index.js";
import dayjs from "dayjs";
import { groupBy } from "@/api/ComUnit.js";
import $ from "jquery";

import { ref, onMounted, provide, inject } from "vue";
// 获取当前主题
const _theme = localStorage.getItem("curTheme");

const zmData = ref();
const bzData = ref();
const zmGQdata = ref();
const bzGQdata = ref();
const GQdata = ref();
const stime = inject("stime");
const etime = inject("etime");
const stcd = inject("stcd");
const stnm = inject("stnm");
const gqstcd = ref();
if (etime.value == "") {
  etime.value = dayjs(new Date()).format("YYYY-MM-DD HH:mm:ss");
}
if (stime.value == "") {
  stime.value = dayjs(dayjs(new Date()).format("YYYY-MM-DD HH:mm:ss"))
    .add(-72, "hour")
    .format("YYYY-MM-DD HH:mm:ss");
}


// 判断弹窗是否显示,默认隐藏
const showDialog = ref(false);
// 传递弹开页面的标题名称
const titleName = ref();
const typeExkey = ref();
const typeEqptp = ref();


const props = defineProps({
  stcd: {
    type: String,
    default: "",
  },
  stime: {
    type: String,
    default: "",
  },
  etime: {
    type: String,
    default: "",
  },
});

function Weacontent() {
  var nowTM = new Date();
  var strJsonAll = []
  var zmstrJsonAll = [], bzstrJsonAll = [];
  var strParam = {};
  strParam["stcd"] = stcd.value;
  strParam["stime"] = stime.value;
  strParam["etime"] = etime.value;

  var res = {
    "total": 1,
    "data": [
      {
        "stcd": "102000",
        "stnm": "杨思枢纽",
        "lgtd": 758.5,
        "gtopnum": 3.0,
        "st_gate_r": [
          {
            "gtq": 0.0,
            "stcd": "102000",
            "tm": "2025-08-19 09:24:00.000000",
            "eqptp": "闸坝开度",
            "exkey": "1",
            "eqpno": "1"
          },
          {
            "gtq": 0.0,
            "stcd": "102000",
            "tm": "2025-08-07 15:18:00.000000",
            "eqptp": "闸坝开度",
            "exkey": "3",
            "eqpno": "1"
          },
          {
            "gtq": 0.0,
            "stcd": "102000",
            "tm": "2025-08-07 15:18:00.000000",
            "eqptp": "闸坝开度",
            "exkey": "2",
            "eqpno": "1"
          },
          {
            "gtq": 0.0,
            "stcd": "102000",
            "tm": "2024-08-30 15:21:00.000000",
            "eqptp": "泵站状态",
            "exkey": "1",
            "eqpno": "2"
          }
        ],
        "omcnum": 1.0,
        "lttd": -7858.0,
        "wrz": null,
        "grz": null,
        "upz": null,
        "sfq": 0.0
      }
    ],
    "dataSize": 0,
    "pageSize": 0,
    "message": "操作成功",
    "isSuccess": true,
    "pageTotal": 0,
    "pageIndex": 0,
    "elapseTime": 20,
    "expand": null
  }
  strJsonAll = res.data[0];
  setTimeout(() => {
    GQload(strJsonAll);
  }, 1000);
}
function GQload(strJsonAll) {
  var tempTM = dayjs(new Date()).format("yyyy-MM-dd 00:00:00");
  var strMsg = "";
  //GTOPNUM闸
  var zmdata = strJsonAll.st_gate_r.filter(function (e) {
    return e.eqpno == 1;
  });
  // omcnum 泵
  var bzdata = strJsonAll.st_gate_r.filter(function (e) {
    return e.eqpno == 2
  });
  for (var num = 0; num < bzdata.length; num++) {
    strMsg += `<fieldset style="border-color: var(--popContentHeadbg);">`;

    var temp1 = bzdata.filter(function (e) {
      return (
        e.exkey == num + 1 &&
        ((Number(e.gtq) > 0 && e.eqptp == "泵站状态") ||
          (e.eqptp == "泵站电流" && Number(e.gtq) > 10))
      );
    });
    var tempXX = `<legend style="font-size: 18px; color: #fff"><label>泵站${num + 1}#信息（<span style="color:red;">关</span>）</label></legend>`;
    if (temp1.length > 0) {
      tempXX = `<legend style="font-size: 18px; color: #fff"><label>泵站${temp1[0].exkey}#信息（<span style="color:#4CE242;">开</span>）</label></legend>`;
    }
    strMsg += tempXX;

    strMsg += `<div class="fieldset-body">`;
    strMsg += `<table style="color: #ffffff; border-width: 1px;border-color: #999999;border-collapse: collapse; width: 100%; height: 100%;">`;
    strMsg += `<thead>`;
    strMsg += `<tr><th>站名</th><th>类型</th><th>状态</th><th>时间</th></tr>`;
    strMsg += `</thead>`;
    strMsg += `</tbody>`;
    var _strMsg = ""
    if (temp1.length > 0) {
      _strMsg += `<tr style="text-align: center;">`;
      _strMsg += `<td style="color: #00ffff;text-decoration: underline;cursor: pointer;width: 40%;" class="${temp1[0].stcd} ${temp1[0].exkey} ${temp1[0].eqptp} ${stnm.value}${temp1[0].exkey}#${temp1[0].eqptp}">${stnm.value}${temp1[0].exkey}#</td>`;
      _strMsg += `<td style="width: 20%;">${temp1[0].eqptp}</td>`;
      if (Number(temp1[0].gtq) > 0) {
        _strMsg += `<td style="width: 20%;">开</td>`;
      } else {
        _strMsg += `<td> style="width: 20%;">关</td>`;
      }
      if (temp1[0].tm != null && temp1[0].tm != "") {
        _strMsg += `<td style="width: 20%;">${dayjs(temp1[0].tm).format("MM-DD HH:mm")}</td>`;
      }
      else {
        _strMsg += `<td style="width: 20%;">—</td>`;
      }
      _strMsg += `</tr>`;
    } else {
      _strMsg += `<tr style="text-align: center;">`;
      _strMsg += `<td style="color: #00ffff;text-decoration: underline;cursor: pointer;width: 40%;" class="${bzdata[num].stcd} ${num + 1} ${bzdata[num].eqptp} ${stnm.value}${num + 1}#${bzdata[num].eqptp}">${stnm.value}${num + 1}#</td>`;
      _strMsg += `<td style="width: 20%;">${bzdata[num].eqptp}</td>`;
      _strMsg += `<td style="width: 20%;">关</td>`;
      if (bzdata[num].tm != null && bzdata[num].tm != "") {
        _strMsg += `<td style="width: 20%;">${dayjs(bzdata[num].tm).format("MM-DD HH:mm")}</td>`;
      } else {
        _strMsg += `<td style="width: 20%;">—</td>`;
      }
      _strMsg += `</tr>`;
    }
    strMsg += _strMsg;
    strMsg += `</tbody>`;
    strMsg += `</table>`;
    strMsg += `</div">`;
    strMsg += `</fieldset>`;
  }


  for (var num = 0; num < zmdata.length; num++) {
    strMsg += `<fieldset  style="border-color: var(--popContentHeadbg);">`;

    var temp1 = zmdata.filter(function (e) {
      return (
        e.exkey == num + 1 &&
        Number(e.gtq) > 0.1 &&
        e.eqptp == "闸坝开度"
      );
    });
    var tempXX = `<legend style="font-size: 18px; color: #fff"><label>闸站${num + 1}#信息（<span style="color:red;">关</span>）</label></legend>`;
    if (temp1.length > 0) {
      tempXX = `<legend style="font-size: 18px; color: #fff"><label>闸站${temp1[0].exkey}#信息（<span style="color:#4CE242;">开</span>）</label></legend>`;
    }
    strMsg += tempXX;

    strMsg += `<div class="fieldset-body">`;
    strMsg += `<table style="color: #ffffff; border-width: 1px;border-color: #999999;border-collapse: collapse; width: 100%; height: 100%;">`;
    strMsg += `<thead>`;
    strMsg += `<tr><th>站名</th><th>类型</th><th>开度(m)</th><th>时间</th></tr>`;
    strMsg += `</thead>`;
    strMsg += `</tbody>`;
    var _strMsg = ""
    if (temp1.length > 0) {
      _strMsg += `<tr style="text-align: center;">`;
      _strMsg += `<td style="color: #00ffff;text-decoration: underline;cursor: pointer;width: 40%;" class="${temp1[0].stcd} ${temp1[0].exkey} ${temp1[0].eqptp} ${stnm.value}${temp1[0].exkey}#${temp1[0].eqptp}">${stnm.value}${temp1[0].exkey}#</td>`;
      _strMsg += `<td style="width: 20%;">${temp1[0].eqptp}</td>`;
      _strMsg += `<td style="width: 20%;">${temp1[0].gtq}</td>`;
      if (temp1[0].tm != null && temp1[0].tm != "") {
        _strMsg += `<td style="width: 20%;">${dayjs(temp1[0].tm).format("MM-DD HH:mm")}</td>`;
      } else {
        _strMsg += `<td style="width: 20%;">—</td>`;
      }
      _strMsg += `</tr>`;
    } else {
      _strMsg += `<tr style="text-align: center;">`;
      _strMsg += `<td style="color: #00ffff;text-decoration: underline;cursor: pointer;width: 40%;" class="${zmdata[num].stcd} ${num + 1} ${zmdata[num].eqptp} ${stnm.value}${num + 1}#${zmdata[num].eqptp}">${stnm.value}${num + 1}#</td>`;
      _strMsg += `<td style="width: 20%;">${zmdata[num].eqptp}</td>`;
      _strMsg += `<td style="width: 20%;">${zmdata[num].gtq}</td>`;
      if (zmdata[num].tm != null && zmdata[num].tm != "") {
        _strMsg += `<td style="width: 20%;">${dayjs(zmdata[num].tm).format("MM-DD HH:mm")}</td>`;
      } else {
        _strMsg += `<td style="width: 20%;">—</td>`;
      }
      _strMsg += `</tr>`;
    }
    strMsg += _strMsg;
    strMsg += `</tbody>`;
    strMsg += `</table>`;
    strMsg += `</div">`;
    strMsg += `</fieldset>`;
  }
  $("#GCJK").html(strMsg);

  // } else {
  //   var strMsg = '<div style="font-size: 30px; text-align: center;margin-top: 200px;color: var(--mtablecolor);">无数据</div>';
  //   $("#divGCJK").html(strMsg);
  // }
}

function handleClick(e) {
  const classList = e.target.classList;
  showDialog.value = true;
  gqstcd.value = classList[0];
  typeExkey.value = classList[1];
  typeEqptp.value = classList[2];
  titleName.value = classList[3];
}
onMounted(() => {
  Weacontent();
  if (_theme == "BlueTheme" || _theme == "VioletTheme") {
    $(".popContent").css("background", "#031426");
    $(".content").css("background", "#031426e6");
  }
});
// 提供方法给子组件
provide("stime", stime);
provide("etime", etime);
provide("gqstcd", gqstcd);
provide("typeExkey", typeExkey);
provide("typeEqptp", typeEqptp);
</script>
 
<style scoped>
.tableGQVoew tr td:nth-child(odd) {
  width: 170px;
}
</style>
