      //   secure: false,
      //   rewrite: (path) => path.replace(new RegExp('^' + '/ArcGis'), ""), // 替换
      // },
      ['/UploadDoc']: {
        target: "http://2.46.42.143:8160/UploadDoc", // 目标地址
        changeOrigin: true, // 是否换源， true 换源
        secure: false,
        rewrite: (path) => path.replace(new RegExp('^' + '/UploadDoc'), ""), // 替换
      },
      ['/systemIndex']: {//验证cas登录的地址：统一登录
        target: "http://localhost:4012/", // 目标地址
        changeOrigin: true, // 是否换源， true 换源
        secure: false,
        rewrite: (path) => path.replace(new RegExp('^' + '/systemIndex'), ""), // 替换
      },
    },
  },
  build: {
    //npm install --save-dev compression-webpack-plugin@1.1.12
    productionGzip:true,
    productionGzipExtensions:['js','css'],
    bundleAnalyzerReport: process.env.npm_config_report,
    
    chunkSizeWarningLimit: 1500,
    outDir: 'swzzLargeScreenSzhGQ', // 打包文件的输出目录
    rollupOptions: {
      output: {
        manualChunks(id) {
          // 将@arcgis/core和esri-loader打包到一个chunk中
          if (id.includes('@arcgis/core') || id.includes('esri-loader')) {
            return 'arcgis';
          }
          if (id.includes('node_modules')) {
            return id
              .toString()
              .split('node_modules/')[1]
              .split('/')[0]
              .toString()
          }
        }
      },
      //  // 用于从入口点创建的块的打包输出格式[name]表示文件名,[hash]表示该文件内容hash值
