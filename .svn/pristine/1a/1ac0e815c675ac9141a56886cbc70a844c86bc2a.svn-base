function JosnSel(data, typeID) {
  if (typeID == "TFLJSel") {
      var strJsonTM = [];
      if (data.data[0].points.length > 0) {
        for (var num = 0; num < data.data[0].points.length; num++) {
          var items = data.data[0].points[num];
