}

.zuo_two {
    height: 50%;
    width: 49%;
    display: inline-block;
    text-align: center;
}

.zuo_two span {
    display: block;
    text-align: center;
    height: 28px;
    line-height: 28px;
}

.zuo_two:nth-child(1) span {
    /* color: #65e7c7; */
    color: #00BFFF;
}

.zuo2_two {
    display: inline-block;
    width: 100%;
}

.zuo2_two div span {
    width: 24%;
    text-align: center;
    display: inline-block;
    height: 28px;
    line-height: 28px;
}

.zuo2_two div:nth-child(1) span {
    /* color: #65e7c7; */
    color: #00BFFF;
}


