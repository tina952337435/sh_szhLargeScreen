}

.image_large {
    position: fixed;
    display: none
}

.g-lsideqixiang {
    top: 9.65rem;
    height: calc(112vh - 11.375rem);
    width: 350px;
}


.triangle-bottomright {
    width: 0px;
    height: 0px;
    border-bottom: 35px solid;
    border-left: 116px solid transparent;
    /* left: 250px; */
    left: 32px;
    border-bottom-color: rgba(1, 1, 1, 0.6);
    position: absolute;
    bottom: 10px;
}

.triangle-bottomright div {
    /*position: absolute;
        left: -90px;
        top: 33px;
        color: white;
        font-size: 17px;*/
    position: absolute;
    left: -75px;
    top: 15px;
    color: white;
    font-size: 15px;
}




/* 气象、fangxun、引江济太 */
.menuTop {
    position: relative;
    /* bottom: 20px; */
}

.menuTop .selected {
    background-color: rgba(0, 163, 255, 0.7);
    background-size: 100% 100%;
}

.menuTop ul li {
    background: url('/images/menuTopSelected.png') no-repeat center;
    background-size: 100% 100%;
    width: 80px;
    height: 32px;
    color: #fff;
    list-style: none;
    float: left;
    margin-right: 10px;
    text-align: center;
    line-height: 32px;
    cursor: pointer;
}


.pic-list {
    height: calc(112vh - 18.375rem);
    overflow: hidden;
    position: relative;
    top: -11px;
    width: 100%;
    overflow-y: auto;
}

/* 自定义滚动条样式 */
.pic-list::-webkit-scrollbar {
    width: 2px;
}

.pic-list::-webkit-scrollbar-thumb {
    /* 滚动条手柄 */
    width: 10px;
    height: 10px;
    position: absolute;
    right: -4px;
    top: 0px;
    background: var(--mtabletrcolor);
    z-index: 2;
}

.pic-list ul {
    position: absolute;
    left: 0px;
    top: 0px;
    padding-inline-start: 0px;
}

.pic-list .zuo-tu {
    background-color: var(--qixianglefttitlebg);
    width: 400px;
    height: calc(calc(112vh - 20.8rem)*(2/6));
    cursor: pointer;
    width: 160px;
    height: 120px;
    float: left;
    border: 1px solid #757272;
    border-radius: 5px;
}

ul .zuo-tu .img {
    width: 100%;
    height: 100%;
    /*margin-left: 10px;
    padding-top: 10px;*/
    cursor: pointer;
    padding: 10px;
}


a {
    text-decoration: none;
}

.img1,
.img2,
.Cont {
    float: left;
}

.img1,
.img2 {
    width: 58px;
    height: 29px;
    display: block;
    opacity: .8;
    filter: alpha(opacity=30);
    cursor: pointer;
}

.img1 {
    background-image: url(/images/forward_1.png);
    background-repeat: no-repeat;
    background-position: center center;
    position: absolute;
    left: 12rem;
    top: 20px;
    z-index: 999;
    cursor: pointer;
}

.img2 {
    background-image: url(/images/back_1.png);
    background-repeat: no-repeat;
    background-position: center center;
    position: absolute;
    left: 12rem;
    bottom: 8rem;
    z-index: 999;
    cursor: pointer;
}

.img1:hover {
    opacity: 1;
    filter: alpha(opacity=100);
}

.img2:hover {
    opacity: 1;
    filter: alpha(opacity=100);
}

.img1,
.img2,
.Cont {
    float: left;
}

.img3,
.img4 {
    width: 58px;
    height: 29px;
    display: block;
    opacity: .3;
    filter: alpha(opacity=30);
    cursor: pointer;
}

.img3 {
    background-image: url(/images/forward_1.png);
    background-repeat: no-repeat;
    background-position: center center;
    position: absolute;
    left: 2rem;
    bottom: 2rem;
    z-index: 999;
    transform: rotate(270deg);
    -ms-transform: rotate(270deg);
    /* IE 9 */
    -moz-transform: rotate(270deg);
    /* Firefox */
    -webkit-transform: rotate(270deg);
    /* Safari 和 Chrome */
    -o-transform: rotate(270deg);
    /* Opera */
    cursor: pointer;
}

.img4 {
    background-image: url(/images/back_1.png);
    background-repeat: no-repeat;
    background-position: center center;
    position: absolute;
    right: 2rem;
    bottom: 2rem;
    z-index: 999;
    transform: rotate(270deg);
    -ms-transform: rotate(270deg);
    /* IE 9 */
    -moz-transform: rotate(270deg);
    /* Firefox */
    -webkit-transform: rotate(270deg);
    /* Safari 和 Chrome */
    -o-transform: rotate(270deg);
    /* Opera */
    cursor: pointer;
}

.img3:hover {
    opacity: 1;
    filter: alpha(opacity=100);
}

.img4:hover {
    opacity: 1;
    filter: alpha(opacity=100);
}

#sld ul li {
    float: left;
    list-style: none;
}

#sld ul {}

.photo-pcul {
    list-style: none;
}

.photo-pcul {
    list-style: none;
}

.photo-pcul li {
    float: left;
}

.mask {
    background: #666;
    position: absolute;
    z-index: 99;
    left: 0;
    top: 0;
    display: none;
    width: 100%;
    height: 100%;
    opacity: 0.5;
    filter: alpha(opacity=50);
    -moz-opacity: 0.5;
}

/*图片放大组件 */
.viewer-backdrop {
    background-color: rgba(0, 0, 0, 0.8);
    z-index: 3;
}

.viewer-footer {
    z-index: 3;
}

.viewer-navbar {
    display: none;
}

#photoPCJZ::-webkit-scrollbar {
    width: 2px;
    /* 设置滚动条宽度 */
}

#photoPCJZ::-webkit-scrollbar-thumb {
    /* 滚动条手柄 */
    width: 10px;
    height: 10px;
    position: absolute;
    right: -4px;
    top: 0px;
    background: var(--mtabletrcolor);
    z-index: 2;
}

.viewer-transition {
    transition: all 0.000000000000000000000001s;
}