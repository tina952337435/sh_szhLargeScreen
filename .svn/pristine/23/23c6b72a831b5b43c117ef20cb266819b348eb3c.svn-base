div.slideBox {
    position: relative;
    width: 100%;
    height: calc(100vh - 14.375rem);
    overflow: hidden;
    /* margin: 30px auto 100px auto; */
}

div.slideBox ul.items {
    position: absolute;
    float: left;
    background: none;
    list-style: none;
    padding: 0px;
    margin: 0px;
}

/* #cesiumContainer {
    display: none;
} */

.qixiangmai {
    width: 100%;
    height: 100%;
    background: var(--qixiangmainbg);
    position: absolute;
    top: 0px;
    left: 0px;
}

.g-rsideqixiang {
    width: calc(100% - 370px);
    margin: 0px;
    height: calc(100% - 10.375rem);
    top: 8.575rem !important;
}

.bjimg {
    background-image: var(--qixiangrightbg);
    background-size: 100% 100%;
    background-repeat: no-repeat;
    width: 100%;
    position: relative;
    height: calc(112vh - 16.375rem);
    /* margin-left: -210px; */
    /* margin-top: -1445px; */
}

.onlytab {
    list-style: none;
    color: #00feff;
    border-color: #00feff;
    /* z-index: 988; */
    height: 40px;
    margin: auto;
    width: 100px !important;
}

.onlytab li:first-child {
    border-radius: .75rem 0 0 .75rem;
}

.onlytab li {
    float: left;
    background-color: #0f637e;
    height: 31px;
    width: 50%;
    text-align: center;
    line-height: 31px;
    cursor: pointer;
}

.onlytab li:last-child {
    border-radius: 0 .75rem .75rem 0;
}

ul .zuo-tu {
    background-color: var(--qixianglefttitlebg);
    width: 400px;
    height: 240px;
    position: relative;
    margin-left: 8px;
    margin-top: 8px;
}

ul .zuo-tu span {
    font-weight: bold;
    padding-left: 5px;
    /* width: 80px; */
    font-size: 20px;
    height: 230px;
    position: absolute;
    margin-top: 18%;
    color: #ccc;
}

.onlyliHover {
    background: none !important;
    color: #042828;
    -webkit-animation-name: onlyliHover;
    -webkit-animation-duration: 3s;
    -webkit-animation-iteration-count: infinite;
}

@-webkit-keyframes onlyliHover {
    from {
        -webkit-box-shadow: 0 0 15px transparent;
    }

    50% {
        -webkit-box-shadow: 0 0 30px #00E4FF;
    }

    to {
        -webkit-box-shadow: 0 0 15px transparent;
    }
}

.weather {
    padding-left: 1.5rem;
    float: left;
    padding-top: 8px;
}

.totalbkind_div {
    margin-left: 190px;
    /*margin-top: -11px;*/
}

.totalbkind_ul {
    list-style: none;
}

.totalbkind_li {
    display: inline-block;
    width: 58px;
}

.totalbkind_li img {
    width: 50px;
    height: 50px;
    padding-top: 18px;
}

.table-color tr td:nth-child(4) {
    color: #65e7c7 !important;
}

