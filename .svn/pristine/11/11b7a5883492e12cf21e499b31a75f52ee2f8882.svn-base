// console.error('stationData',JSON.stringify(stationData));
var _index=1;
var dataNew=[];
 areaData.map(e=>{
    var stationDataTemp=stationData.filter(function(ea){
        ea.drp=Number(ea.drp);
        return ea.hnnm==e;
    });
    if(stationDataTemp.length>0){
        stationDataTemp=sortObjectArray(stationDataTemp, ['drp'], 'desc');
        // console.error(e,stationDataTemp);
        var drpTotal= SumJson(stationDataTemp,'drp')
        var drpAvg=drpTotal/stationDataTemp.length;
        var maxdrp=Number(stationDataTemp[0].drp).toFixed(1);
        var item={sortnum:_index,name:e,drp:drpAvg.toFixed(1),maxstnm:stationDataTemp[0].stnm,maxdrp:maxdrp};
        dataNew.push(item);
       _index++;
    }
   
});
dataNew=sortObjectArray(dataNew, ['maxdrp'], 'desc');
dataNew.filter(function(e,_index){
    e.sortnum=_index+ 1;
});
tableData.value=dataNew;
// console.error('stationData',JSON.stringify(stationData));

const strNote = [];
      strNote.push({ name: "名称", codename: "name", tableV: "0", isShow: true });
      strNote.push({ name: "雨量", codename: "drp", tableV: "0", isShow: true });
      var LineColor = [
        "#3E8BFF",
        "#1CB8B2",
        "#01DDFF",
        "#F9C823",
        "#0264FD",
        "#FE7923",
        "#8E30FF",
      ];
      const _Option = ChartJs.chartYL(
        "",
        dataNew,
        strNote,
        LineColor,
        "雨量",
        "true",
        _theme
      );
      lineOption.value = _Option;
      datekey.value = Date.now();
}

function fangda() {
  var dialogClass = $(".dialog").css("display");
  if (dialogClass == "block") {
    return false;
  }
  $(".g-lside ").css({ "z-index": 90 });
  $(".g-rside ").css({ "z-index": 99 });
  showDialog.value = true;
  dateid.value = "daydrpAvg1";
}
onMounted(() => {
  var now = new Date();
  stime.value = dayjs(now).format("YYYY-MM-DD 08:00:00");
  if (dayjs(now).format("HH") < 8) {
    stime.value = dayjs(dayjs(now).format("YYYY-MM-DD 08:00:00"))
      .add(-1, "day")
      .format("YYYY-MM-DD HH:mm:ss");
  } else {
    stime.value = dayjs(now).format("YYYY-MM-DD 08:00:00");
  }
  etime.value = dayjs(now).format("YYYY-MM-DD HH:mm:ss");

  // stime.value = "2025-05-08 08:00:00";
  // etime.value = "2025-05-08 23:00:00";
  Weacontent();
});
