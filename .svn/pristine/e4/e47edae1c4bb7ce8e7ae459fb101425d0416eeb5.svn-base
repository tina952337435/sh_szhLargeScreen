onUnmounted(() => {
  $(".light").remove();
  if (interVal != null) {
    clearInterval(interVal);
  }
  clearALL();
})
onMounted(() => {

  var _htmlIframe = (window.location.href).split("=")[1];
  if (_htmlIframe == "htmlIframeWQ") {
    $(".header").css({ "z-index": 99, "display": "none" });
    $(".aside").css({ "z-index": 99, "display": "none" });
    $(".g-rside").css({ "z-index": 999, "top": "0rem" });
    $(".btnList").css({ "z-index": 999, "top": "1rem" });
  }

  setTimeout(function () {
    clearALL();
    addAreaLineQS();
  }, 50)
  addObjClick();

  $("#tabwq").addClass("swDivSelect swDiv");  
  $("#swDivMoreUL ul #tabwq").css("color", "var(--swDivSelectcolor)");
