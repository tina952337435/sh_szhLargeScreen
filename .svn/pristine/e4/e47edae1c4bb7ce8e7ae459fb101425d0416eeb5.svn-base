      var strJson = res.result;
      if (strJson.length > 0) {
        for (var num = 0; num < strJson.length; num++) {
          var properties=weiquURL.features[num].properties;
          strJson[num].wqname=properties["圩区名"];
          strJson[num].wqid=properties["OBJECTID"];
          var itemList = [];
          if (SetNull(strJson[num]["waterList"]) != "") {
            itemList = sortObjectArray(strJson[num]["waterList"], ["dwz"], "desc");
            strJson[num]["maxUpz"] = itemList[0]["dwz"];
          }
        }
      }
      wqstrJson.value = strJson;
      bindData();
      window.loadingHide();
