//自动刷新
var interVal;
window.curDataRefresh = function () {
  if (interVal != null) {
    clearInterval(interVal);
  }
  if (localStorage.getItem("curDataRefresh") == "true") {
    interVal = setInterval(function () {
      refreshData();
    }, 180000);//180000
  }
}
//刷新的方法
function refreshData() {
  var _curDataRefresh = localStorage.getItem("curDataRefresh");
  if (_curDataRefresh == true || _curDataRefresh == 'true') {
    WQTab();
  } else {
    if (interVal != null && interVal != undefined) {
      clearInterval(interVal);
    }
  }
}
function bindData(AllName) {
  if (AllName) {
    pidSW.value = "20241025000002";
    pidLL.value = "20241113000002";
    pidGQ.value = "2024112915257711257";
    pidWSJ.value = "000001";
    $(".LabelPlotBeautifulDRP").remove();
    $(".LabelPlotBeautifulTGTQ").remove();
    $(".LabelPlotBeautiful-container").remove();
    $(".lightLL").remove();
    $(".lightWSJ").remove();
    AreaName.value = AllName;
    riverMarker.value = false;
    LLMarker.value = false;
    GQMarker.value = false;
    GCMarker.value = false;
    WSJMarker.value = false;
    labelSW.value = "水位";
    labelGC.value = "工程";
    labelLL.value = "流量";
    labelGQ.value = "工情";
    labelWSJ.value = "污水井";
  }
  var strJson = wqstrJson.value;
  var CheckArr = getInputCheck();
  var tableData = ybdrplist.length == undefined ? ybdrplist.value : ybdrplist;

  //圩区画面
  PointMark.addWQMark(strJson);
}
function clearALL() {
  try {
    removeEntityByName();

  } catch (ex) {
    console.error("clearALL",ex.Message);
   }
}
function getInputCheck() {
  var CheckArr = {};
  if (
    tabWQname.value == "windDefault" ||
    tabWQname.value == "radarDefault" ||
    tabWQname.value == "ddDefault"
  ) {
    CheckArr = {
      colorLSW1: $("#colorLSW1").is(":checked"),
      colorLSW2: $("#colorLSW2").is(":checked"),
      colorLSW3: $("#colorLSW3").is(":checked"),
      colorLSW4: $("#colorLSW4").is(":checked")
    };
  } else if (tabWQname.value == "rainDefault") {
    CheckArr = {
      colorLNYL1: $("#colorLNYL1").is(":checked"),
      colorLNYL2: $("#colorLNYL2").is(":checked"),
      colorLNYL3: $("#colorLNYL3").is(":checked"),
      colorLNYL4: $("#colorLNYL4").is(":checked"),
      colorLNYL5: $("#colorLNYL5").is(":checked"),
      colorLNYL6: $("#colorLNYL6").is(":checked"),
      colorLNYL7: $("#colorLNYL7").is(":checked")
    };
  } else if (tabWQname.value == "tempDefault") {
    CheckArr = {
      colorPLNL0: $("#colorPLNL0").is(":checked"),
      colorPLNL1: $("#colorPLNL1").is(":checked"),
      colorPLNL2: $("#colorPLNL2").is(":checked"),
      colorPLNL3: $("#colorPLNL3").is(":checked"),
      colorPLNL4: $("#colorPLNL4").is(":checked"),
      colorPLNL5: $("#colorPLNL5").is(":checked")
    };
  }
  return CheckArr;
}
function addObjClick() {
  $("input[name='colorLSW']").click(function (res) {
    var objID = $(this).attr("id");
    clearALL();
    bindData();
  });
  $("input[name='colorSCLSW']").click(function (res) {
    var objID = $(this).attr("id");
    clearALL();
    bindData();
  });
  $("input[name='colorLNYL']").click(function (res) {
    var objID = $(this).attr("id");
    clearALL();
    bindData();
  });
  $("input[name='colorPLNL']").click(function (res) {
    var objID = $(this).attr("id");
    clearALL();
    bindData();
  });
  $("input[name='colorTJDD']").click(function (res) {
    var objID = $(this).attr("id");
    clearALL();
    bindData();
  });
}
function OnBoot() {
  const type = "预报降雨";
  tabWQnameType.value = type;
  const ChildVue = defineAsyncComponent(() =>
    import("@/components/danzhan/wq/setViewJson.vue")
  );
  currentComponentTanchu.value = ChildVue;
  $(".popupContent .head span").html(type);
  $(".popModel").show();
}
const cancel = () => {
  $("#mypopModel").hide();
};
const parentMethod = res => {
  $("#mypopModel").hide();
  // console.error("父组件的方法被调用", res);
  ybdrplist = res;
  WQTab();
};

const strJsonData = ref([]);
const riverMarker = ref(false);
const GCMarker = ref(false);
const LLMarker = ref(false);
const GQMarker = ref(false);
const WSJMarker = ref(false);
const pidSW = ref("20241025000002");
const pidLL = ref("20241113000002");
const pidGQ = ref("2024112915257711257");
const pidWSJ = ref("202504140951001");
const labelSW = ref("水位");
const labelGC = ref("工程");
const labelLL = ref("流量");
const labelGQ = ref("工情");
const labelWSJ = ref("污水井");
// 水位
function WeacontentSW(typeTRue) {
  $(".LabelPlotBeautiful-container").remove();
  window.loadingShow();
  var now = new Date();
  var etime = dayjs(now).format("YYYY-MM-DD HH:mm:ss");
  if (Number(dayjs(now).format("HH")) > 7) {
    var stime = dayjs(now).format("YYYY-MM-DD 08:00:00");
  }
  else {
    var stime = dayjs(dayjs(now).format("YYYY-MM-DD 08:00:00"))
      .add(-24, "hour")
      .format("YYYY-MM-DD HH:mm:ss");
  }
  var strParam = {};
  strParam["pid"] = pidSW.value;
  strParam["pathname"] = "1";
  api.stStbprpBStcdFindResult(strParam).then((res) => {
    const resultList = groupBy(res.result, "stcd");
    var strJson = [];
    if (resultList.length > 0) {
      for (var num = 0; num < resultList.length; num++) {
        var item = resultList[num][0];
        item["tm"] = item["ztm"];
        strJson.push(item);
      }
    } 

    strJsonData.value = strJson;
    SWload(stime, etime, typeTRue);
    window.loadingHide();
  });
}
// 流量
function WeacontentLL() {
  // window.loadingShow();
  var nowTM = new Date();
  var etime = dayjs(nowTM).format("YYYY-MM-DD HH:mm:ss");
  var stime = dayjs(nowTM).format("YYYY-MM-DD 08:00:00");
  if (Number(dayjs(nowTM).format("HH")) > 7) {
    stime = dayjs(nowTM).format("YYYY-MM-DD 08:00:00");
  }
  else {
    stime = dayjs(dayjs(nowTM).format("YYYY-MM-DD 08:00:00"))
      .add(-24, "hour")
      .format("YYYY-MM-DD HH:mm:ss");
  }
  // 流量
  var strWhere = {}
  strWhere["pathname"] = "NEW";
  strWhere["pid"] = pidLL.value;
  strWhere["pathname"] = "5";
  api.stStbprpBStcdFindResult(strWhere).then((res) => {
    const resultList = groupBy(res.result, "stcd");
    const strJson = [];
    if (resultList.length > 0) {
      for (var num = 0; num < resultList.length; num++) {
        var item = resultList[num][0];
        item["q"] = item["upz"];
        item["tm"] = item["ztm"];
        strJson.push(item);
      }
    }

    labelLL.value = "流量(" + strJson.length + ")"
  });
  window.loadingHide();
}
// 工情
function WeacontentGQ() {
  // window.loadingShow();
  var nowTM = new Date();
  var etime = dayjs(nowTM).format("YYYY-MM-DD HH:mm:ss");
  var stime = dayjs(nowTM).format("YYYY-MM-DD 08:00:00");
  if (Number(dayjs(nowTM).format("HH")) > 7) {
    stime = dayjs(nowTM).format("YYYY-MM-DD 08:00:00");
  }
  else {
    stime = dayjs(dayjs(nowTM).format("YYYY-MM-DD 08:00:00"))
      .add(-24, "hour")
      .format("YYYY-MM-DD HH:mm:ss");
  }
  var strWhere = {};
  strWhere["pathname"] = "NEW";
  strWhere["pid"] = pidGQ.value;
  strWhere["stime"] = stime;
  strWhere["etime"] = etime;
  api.stPptnGQTable(strWhere).then((res) => {
    const strJson = groupBy(res.result, "stnm");

    var strResult = [];
    var result = [];
    if (strJson.length > 0) {
      for (var num = 0; num < strJson.length; num++) {
        var item = strJson[num];
        var stnm = item[0].stnm
        if (item[0].stGateR != undefined) {
          var tm = item[0].stGateR[0].tm
        } else {
          var tm = "—"
        }

        for (var i = 0; i < item.length; i++) {
          var stGateRData = [];
          var state = -1;
          var bengNo = -1, zhaNo = -1;
          var stcdbz, stcdzm;
          var flpq = 0, grq = 0;
          var bzdataALL = item.filter(function (e) {
            return e.mtype == "泵站";
          });
          var zmdataALL = item.filter(function (e) {
            return e.mtype == "闸站";
          });
          if (bzdataALL.length > 0) {
            stcdbz = bzdataALL[0].stcd;
            var bengNoIndex = 0;
            flpq = bzdataALL[0].num; //泵站个数
            if (bzdataALL[0].stGateR != undefined) {
              var bzdata = bzdataALL[0].stGateR;
              flpq = bzdata.length
              for (var i = 0; i < bzdata.length; i++) {
                if (Number(bzdata[i].gtq) > 0) {
                  bengNoIndex = bengNoIndex + 1
                }
                stGateRData.push(bzdata[i])
              }
            }
            if (bengNoIndex > 0) {
              bengNo = 1
            } else {
              bengNo = 0
            }
          } else {
            stcdbz = ""
          }
          if (zmdataALL.length > 0) {
            stcdzm = zmdataALL[0].stcd;
            var zhaNoIndex = 0;
            grq = zmdataALL[0].num; //闸门个数
            if (zmdataALL[0].stGateR != undefined) {
              var zmdata = zmdataALL[0].stGateR;
              grq = zmdata.length; //闸门个数
              for (var i = 0; i < zmdata.length; i++) {
                if (Number(zmdata[i].gtq) > 0.02) {
                  // zhaNo = 1
                  zhaNoIndex = zhaNoIndex + 1
                } else {
                  // zhaNo = 0
                }
                stGateRData.push(zmdata[i])
              }
            }
            if (zhaNoIndex > 0) {
              zhaNo = 1
            } else {
              zhaNo = 0
            }
          } else {
            stcdzm = ""
          }

          if (bengNo > 0 || zhaNo > 0) {
            state = 1;
          } else if (bengNo > -1 || zhaNo > -1) {
            state = 0;
          } else {
            state = -1;
          }
        }
        var upz = item[0].upz, dwz = item[0].dwz;
        if (zmdataALL.length) {
          upz = zmdataALL[0].upz;
          dwz = zmdataALL[0].dwz;
        }
        var item = {
          stcd: item[0].stcd,
          stcdbz: stcdbz,
          stcdzm: stcdzm,
          stnm: stnm,
          stGateR: item[0].stGateR,
          gateList: stGateRData,
          upz: upz,
          dwz: dwz,
          tm: tm,
          lgtd: Number(item[0].lgtd),
          lttd: Number(item[0].lttd),
          state: state,
          flpq: Number(flpq),
          grq: Number(grq),
          mtype: item[0].mtype,
          mapsize: item[0].mapsize,
          dir: item[0].dir,
        };
        strResult.push(item);
      }
    }

    labelGQ.value = "工情(" + strResult.length + ")"
    $(".LabelPlotBeautifulTGTQ").css({ display: "none" });
  });

  window.loadingHide();
}
// 工程
function WeacontentGC() {
  // window.loadingShow();
  var strParam = {};
  if (AreaNameGC.value == "pathname" && AreaName.value != "全部") {
    strParam["pathname"] = AreaName.value;
  } else if (AreaNameGC.value == "datasource" && AreaName.value != "全部") {
    strParam["datasource"] = AreaName.value;
  }
  strParam["pid"] = "泵站,雨水排站";
  api.WQFindResult(strParam).then(res => {
    // console.error("res", res);
    var result = [];
    if (res.result.length > 0) {
      for (var num = 0; num < res.result.length; num++) {
        var item = res.result[num];
        result.push(item);
      }
    }
    labelGC.value = "工程(" + result.length + ")"
  })
  window.loadingHide();
}

// 污水井
function WeacontentWSJ() {
  // window.loadingShow();
  var strParam = {};

  var nowTM = new Date();
  var etime = dayjs(nowTM).format("YYYY-MM-DD HH:mm:ss");
  var stime = dayjs(nowTM).format("YYYY-MM-DD 08:00:00");
  if (Number(dayjs(nowTM).format("HH")) > 7) {
    stime = dayjs(nowTM).format("YYYY-MM-DD 08:00:00");
  }
  else {
    stime = dayjs(dayjs(nowTM).format("YYYY-MM-DD 08:00:00"))
      .add(-24, "hour")
      .format("YYYY-MM-DD HH:mm:ss");
  }
  strParam["stime"] = stime;
  strParam["etime"] = etime;
  strParam["pid"] = pidWSJ.value;
  api.WS_3HSCADASlectList(strParam).then(res => {
    // console.error("res", res);
    const resultList = groupBy(sortObjectArray(res.result, ["datetime"], "desc"), "rtuname");
    var result = [];
    if (res.result.length > 0) {
      for (var num = 0; num < res.result.length; num++) {
        var item = res.result[num];
        result.push(item);
      }
    }

    var strJson = [];
    if (resultList.length > 0) {
      for (var num = 0; num < resultList.length; num++) {
        var item = resultList[num][0];
        item["tm"] = item["datetime"];
        strJson.push(item);
      }
    }

    strJsonData.value = strJson;
    labelWSJ.value = "污水井(" + strJson.length + ")"
  })
  window.loadingHide();
}

function SWload(stime, etime) {
  var strResult = strJsonData.value;
  // var strResult = [];
  // if (strJson.length > 0) {
  //   for (var i = 0; i < strJson.length; i++) {
  //     var item = strJson[i];
  //     strResult.push(item);

  //   }
  // }
  labelSW.value = "水位(" + strResult.length + ")"; 
}
function SpanItem(obj) {
  if (obj == "riverMarker") { 
    if (riverMarker.value == true) {
      try {
        $(".LabelPlotBeautiful-container").remove();
      } catch (ex) { }
    } else {
      WeacontentSW();
    }
  } else if (obj == "GQMarker") {
    if (GQMarker.value == true) {
      try {
        $(".LabelPlotBeautifulTGTQ").remove();
      } catch (ex) { }
    } else {
      WeacontentGQ();
    }
  } else if (obj == "LLMarker") {
    if (LLMarker.value == true) {
      $(".lightLL").remove();
    } else {
      WeacontentLL();
    }
  } else if (obj == "GCMarker") {
    if (GCMarker.value == true) {
      $(".LabelPlotBeautifulDRP ").remove();
    } else {
      WeacontentGC();
    }
  } else if (obj == "WSJMarker") {
    if (WSJMarker.value == true) {
      $(".lightWSJ").remove();
    } else {
      WeacontentWSJ();
    }
  }

}
provide("tabWQname", tabWQname);
provide("ybdrplist", ybdrplist);
provide("tabWQnameArr", ybdrplist);
provide("tabWQnameType", tabWQnameType);
</script> 

