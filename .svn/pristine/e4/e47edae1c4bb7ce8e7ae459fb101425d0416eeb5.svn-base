  }
}

// 行政分区
function bjLayers(obj) {
  XZpathname.value = "";
  AreaName.value = obj;
  AreaNameGC.value = "pathname";
  lines = reactive([]);
  if (obj == "全部") {
    // clearALL();
    // bindData();
    pidSW.value = "20241025000002"
  } else {
    XZpathname.value = obj;
  }

  bindData();

  if (riverMarker.value == true) {
    $(".LabelPlotBeautiful-container").remove();
    WeacontentSW();
  }
  if (GCMarker.value == true) {
    $(".LabelPlotBeautifulDRP").remove();
