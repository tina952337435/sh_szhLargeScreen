    import("@/components/menu/wq/TableWQ.vue")
  );
  currentComponent.value = customModal;
  provide('XZpathname', XZpathname);
}
// 河湖
function RiverLayers(obj) {
  // 移除所有 tr 元素的 active 类名
  const allTrs = document.querySelectorAll('.wq-table tr');
  allTrs.forEach(tr => {
    tr.classList.remove('liSelected');
  });
  AreaName.value = obj;
  AreaNameGC.value = "datasource";
  lines = reactive([]);
  const data = River["features"];
  for (var num = 0; num < data.length; num++) {
    if (obj == data[num].properties["河流名称"]) {
      var features = data.filter(function (res) {
        return res.properties["河流名称"] == obj;
      });

      const strJsonList = features[0]["geometry"]["coordinates"][0];
      if (strJsonList.length > 0) {
        for (let num = 0; num < strJsonList.length; num++) {
          let items = strJsonList[num];
          lines.push(items[0]);
          lines.push(items[1]);
        }
      }
    }
  }
  bindData();
  if (riverMarker.value == true) {
    $(".LabelPlotBeautiful-container").remove();
    WeacontentSW();
  }
  if (GCMarker.value == true) {
    $(".LabelPlotBeautifulDRP ").remove();
    WeacontentGC();
  }
  if (GQMarker.value == true) {
    $(".LabelPlotBeautifulTGTQ").remove();
    WeacontentGQ();
  }
  if (LLMarker.value == true) {
    $(".lightLL").remove();
    WeacontentLL();
  }
  if (WSJMarker.value == true) {
    $(".lightWSJ").remove();
    WeacontentWSJ();
  }
}
