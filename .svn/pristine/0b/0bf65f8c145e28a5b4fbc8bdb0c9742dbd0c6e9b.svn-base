function YLLoad(obj) {
	emit("parentloadWQRain", obj);
}
// 定义计算 drp 总和的函数
function calculateDrpSum(item) {
	return item.reduce((sum, subItem) => {
		const drp = subItem.drp;
		// 累加 drp 值，若 drp 不存在则默认为 0
		return SetNull(drp) !== "" ? sum + Number(drp) : sum;
	}, 0);
};
//日雨量柱状图
function Weacontent() {
	var rainListAll = props.rainListAll;
	var result = [];
	var bhq = 0, pnq = 0, ycq = 0, dmq = 0, xsq = 0, yxq = 0;
	if (rainListAll.length > 0) {
		for (var num = 0; num < rainListAll.length; num++) {
			var item = rainListAll[num];
			if (item.id == "23010517") {
				xsq = calculateDrpSum(item.rainList);
			} else if (item.id == "23010518") {
				yxq = calculateDrpSum(item.rainList);
			} else if (item.id == "23010519") {
				ycq = calculateDrpSum(item.rainList);
			} else if (item.id == "23010520") {
				dmq = calculateDrpSum(item.rainList);
			} else if (item.id == "23010521") {
				bhq = calculateDrpSum(item.rainList);
			} else if (item.id == "23010522") {
				pnq = calculateDrpSum(item.rainList);
			}
		}
	}

	bhq = (Number(bhq).toFixed(1));
	pnq = (Number(pnq).toFixed(1));
	ycq = (Number(ycq).toFixed(1));
	dmq = (Number(dmq).toFixed(1));
	xsq = (Number(xsq).toFixed(1));
	yxq = (Number(yxq).toFixed(1));

	$("#BHQ").html(bhq);
	var color = getRainColor(bhq).split("@");
	$("#BHQ").css("color", color[1]);
	$("#BHQPATH").attr("fill", color[0]);
	$("#BHQPATH1").attr("fill", color[0]);
	$("#BHQPATH2").attr("fill", color[0]);
	$("#BHQPATH3").attr("fill", color[0]);
	$("#BHQPATH4").attr("fill", color[0]);
	$("#BHQTXT").attr("fill", color[1]);
	if (bhq > 0) {
		$("#BHQPATH").attr("stroke", "#ffffff");
		$("#BHQPATH1").attr("stroke", "#ffffff");
		$("#BHQPATH2").attr("stroke", "#ffffff");
		$("#BHQPATH3").attr("stroke", "#ffffff");
		$("#BHQPATH4").attr("stroke", "#ffffff");
	} else {
		$("#BHQPATH").attr("stroke", "#000000");
		$("#BHQPATH1").attr("stroke", "#000000");
		$("#BHQPATH2").attr("stroke", "#000000");
		$("#BHQPATH3").attr("stroke", "#000000");
		$("#BHQPATH4").attr("stroke", "#000000");
	}

	$("#PNQ").html(pnq);
	color = getRainColor(pnq).split("@");
	$("#PNQ").css("color", color[1]);
	$("#PNQPATH").attr("fill", color[0]);
	$("#PNQTXT").attr("fill", color[1]);
	if (pnq > 0) {
		$("#PNQPATH").attr("stroke", "#ffffff");
	} else {
		$("#PNQPATH").attr("stroke", "#000000");
	}

	$("#YCQ").html(ycq);
	color = getRainColor(ycq).split("@");
	$("#YCQ").css("color", color[1]);
	$("#YCQPATH").attr("fill", color[0]);
	$("#YCQTXT").attr("fill", color[1]);
	if (ycq > 0) {
		$("#YCQPATH").attr("stroke", "#ffffff");
	} else {
		$("#YCQPATH").attr("stroke", "#000000");
	}

	$("#DMQ").html(dmq);
	color = getRainColor(dmq).split("@");
	$("#DMQ").css("color", color[1]);
	$("#DMQPATH").attr("fill", color[0]);
	$("#DMQPATH").attr("fill", color[0]);
	$("#DMQTXT").attr("fill", color[1]);
	if (dmq > 0) {
		$("#DMQPATH").attr("stroke", "#ffffff");
	} else {
		$("#DMQPATH").attr("stroke", "#000000");
	}

	$("#XSQ").html(xsq);
