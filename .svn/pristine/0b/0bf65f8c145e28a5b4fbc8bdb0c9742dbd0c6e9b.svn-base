	$("#XSQ").css("color", color[1]);
	$("#XSQPATH").attr("fill", color[0]);
	$("#XSQTXT").attr("fill", color[1]);
	if (xsq > 0) {
		$("#XSQPATH").attr("stroke", "#ffffff");
	} else {
		$("#XSQPATH").attr("stroke", "#000000");
	}

	$("#YXQ").html(yxq);
	color = getRainColor(yxq).split("@");
	$("#YXQ").css("color", color[1]);
	$("#YXQPATH").attr("fill", color[0]);
	$("#YXQTXT").attr("fill", color[1]);
	if (yxq > 0) {
		$("#YXQPATH").attr("stroke", "#ffffff");
	} else {
		$("#YXQPATH").attr("stroke", "#000000");
	}

}
