// 根据降雨值分颜色

function getRainColor(value) {
	value = Number(value);
	var color = "rgba(10,18,51)";
	var txtColor = "#ffffff";
	color = "#efefef";
	txtColor = "#000000";
	if (value > 0 && value < 10) {
		color = "#A7F387";
		txtColor = "#000000";
	}
	else if (value >= 10 && value < 25) {
		color = "#39BC39";
		txtColor = "#000000";
	}
	else if (value >= 25 && value < 50) {
		color = "#62B7FE";
		txtColor = "#ffffff";
	}
	else if (value >= 50 && value < 100) {
		color = "#0004F6";
		txtColor = "#ffffff";
	}
	else if (value >= 100 && value < 250) {
		color = "#F801FA";
	}
	else if (value >= 250) {
		color = "#800140";
	}
	return color + "@" + txtColor;
}

const emit = defineEmits(['parentloadWQRain']);
