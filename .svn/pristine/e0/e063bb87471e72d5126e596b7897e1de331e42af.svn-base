}

:deep(.el-button) {
    /* background-color: var(--popContentHeadbg);
  border-color: var(--popContentHeadbg); */
    color: #fff;
}

:deep(.el-checkbox__input.is-checked+.el-checkbox__label),
:deep(.el-radio__input.is-checked+.el-radio__label) {
