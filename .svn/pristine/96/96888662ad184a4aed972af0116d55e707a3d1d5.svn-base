/* 定义动画 */
.fade-enter-active,
.fade-leave-active {
  transition: opacity 15.5s ease;
}

.fade-enter-from,
.fade-leave-to {
  opacity: 0;
}

.setup {
  position: absolute;
  width: 340px;
  height: 100%;
  top: 0px;
  /* height: calc(100% - 700px);
    top: 5rem; */
  right: 0px;
  background-color: var(--mboxtxtcolor);
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
  transition: all 3s;
  z-index: 100;
  display: block !important;
  color: var(--widgetcolor);
  animation: fadeIn 2s;
  text-align: left;
  /* 持续时间，重复次数 */
}

.setup .popupContentTitleText {
  text-align: left;
  padding: 0px 10px;
}

.setting {
  width: 100%;
  margin: 0px 30px;
}

.setting-item {
  height: 40px;
  line-height: 40px;
}

.switch-xs {
  position: absolute;
  right: 30px;
  height: 40px;
  line-height: 40px;
}

.settingMap {
  width: 100%;
  margin: 0px 0px 10px 10px;
}

.settingMap-item {
  height: 60px;
  line-height: 60px;
  margin-top: 10px;
}

.settingIcon {
  width: 100%;
  margin: 0px 0px 10px 10px;
}

.settingIcon-item {
  height: 28px;
  line-height: 28px;
  /* margin-top: 10px; */
}

.settingIcon-box {
  width: 40px;
  height: 32px;
  display: inline-block;
  margin-right: 10px;
}

.settingIcon-title {
  text-align: center;
  padding: 0px 5px;
}

.iconSelect {
  background: var(--innerColor);
  border-radius: 10px;
}

.switch-img {
  display: inline-block;
  width: 100px;
  height: 60px;
  line-height: 60px;
  padding: 0 5px;
  position: relative;
  transition: transform 1s, width 1s, height 1s;
  /* 定义过渡效果的时间为1秒 */
  transform-origin: center;
  /* 定义变形的中心点，默认是元素的中心 */
}

.switch-img img {
  width: 100%;
  height: 100%;
  line-height: 40px;
  cursor: pointer;
  border-radius: 5px;
}

.switch-img:hover {
  transform: scale(1.2);
  /* 鼠标移入时放大 */
}

.switch-img img:hover {
  border: solid 2px #05c7c7;
}

.switch-imgSelect {
  display: inline-block;
  width: 100px;
  height: 60px;
  line-height: 40px;
  padding: 0 5px;
}

.switch-imgSelect img {
  width: 100%;
  height: 100%;
  line-height: 40px;
  border: solid 2px #05c7c7;
  cursor: pointer;
  border-radius: 5px;
}

.settingMaptext-xs {
  position: absolute;
  right: 5px;
  bottom: 2px;
  height: 20px;
  line-height: 20px;
  color: #fff;
  font-size: 15px;
  padding: 0px 5px;
  background: #217dc1;
  border-radius: 5px;
}

.divider {
  width: 92%;
  margin: 0 auto;
  text-align: center;
  color: var(--widgetcolor);
  width: center;
  font-size: 15px;
  font-weight: 500;
  height: 36px;
  line-height: 36px;
  /* background-color: var(--dividerColor); */
  /* padding: 0 20px; */
  /* position: absolute; */
  /* left: 50%; */
  /* transform: translateX(-50%) translateY(-50%);*/
}

.divider-text {
  display: inline-block;
  width: 30%;
  vertical-align: -4px;
}

.divider-horizontal {
  border-top: var(--titleborder);
  display: inline-block;
  width: 35%;
}

/* 定义关键帧 */
@keyframes fadeIn {
  0% {
    opacity: 0;
    transform: translateY(20px);
  }

  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 地图底图 */
.mapTool {
  position: absolute;
  height: 40px;
  top: 7.25rem;
  right: 33.2rem;
  z-index: 222;
  width: 60px;
  z-index: 99;
}

.mapTool li {
  width: 35px;
  height: 32px;
  line-height: 37px;
  text-align: center;
  border-radius: 50%;
  background: rgb(28 177 195 / 40%);
  margin-top: 5px;
  cursor: pointer;
  color: white;
  padding: 0px;
  border-radius: 4px;
  list-style: none;
}

.mapTool .exp2 {
  position: absolute;
  top: 0px;
  /* left: -276px; */
  border-radius: 5px;
  width: 260px;
  height: 58px;
  background: #fff;
  background: rgba(10, 19, 42, 0.64);
  padding: 3px;
  right: 20px;
}

.mapTool .exp2 .exp2-menu {
  width: 70px;
  height: 50px;
  display: inline-block;
  position: relative;
  -webkit-box-shadow: 0 0 5px 0 rgb(0 0 0 / 24%);
  box-shadow: 0 0 5px 0 rgb(0 0 0 / 24%);
  border-radius: 4px;
}

.mapTool .exp2 .exp2-menu span {
  position: absolute;
  bottom: 0;
  right: 0;
  display: inline-block;
  padding: 3px 3px 2px 4px;
  font-size: 15px;
  height: 15px;
  line-height: 12px;
  color: #000;
  border-top-left-radius: 2px;
  background: rgba(255, 255, 255, 0.8);
}

.fade-enter-active,
.fade-leave-active {
  transition: opacity 1.5s ease;
}

.fade-enter-from,
.fade-leave-to {
  opacity: 0;
}

.el-radio,
.el-checkbox.el-checkbox--large {
  color: var(--widgetcolor);
  min-width: 66px;
  padding: 0px;
  margin: 0px;
}

:deep(.el-radio__label) {
  padding-left: 2px !important;
}

:deep(.el-checkbox__label) {
  padding-left: 2px !important;
  color: var(--widgetcolor);
}

.ThemeImg {
  vertical-align: -9px;
}

.ThemeImgSapn {
  vertical-align: 9px !important;
}

:deep(.el-checkbox__input.is-checked + .el-checkbox__label) {
  color: var(--innerColor);
}

:deep(.el-checkbox__input.is-checked .el-checkbox__inner) {
  background-color: var(--innerColor);
  border-color: var(--innerColor);
}

:deep(.el-checkbox.el-checkbox--large .el-checkbox__label) {
  font-size: 15px;
}

:deep(.el-radio__input.is-checked .el-radio__inner) {
  background-color: var(--innerColor);
  border-color: var(--innerColor);
}

:deep(.el-radio__input.is-checked + .el-radio__label) {
  color: var(--innerColor);
}

.el-checkbox__input.is-checked .el-checkbox__inner::after {
  /* border-color: #000000 !important;
  background-color: #000000 !important; */
  border-color: var(--el-checkbox-checked-icon-color);
  transform: rotate(45deg) scaleY(1);
}

.divArea {
  width: 100%;
  height: 100px;
  margin: 0px;
  padding: 0px 0px 0px 10px;
}