var maxArr = [], wrzDataS = [], grzDataS = [];
for (var num = 0; num < data.length; num++) {
     maxArr.push(192.62);
     wrzDataS.push(154.47);
     grzDataS.push(192.62);
}
onMounted(() => {
    JsonLineChart(data, maxArr, wrzDataS, grzDataS);
