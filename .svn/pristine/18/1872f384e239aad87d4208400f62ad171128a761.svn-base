function JsonLineChart(strJson, maxArr, wrzDataS, grzDataS) {
            var strData = "";
            //绘制数据说明
            var LineColor = ['#FFA500', '#ff0909'];
            var strNote = [
                {"name": "时间","codename": "TM","tableV":"1","isShow":true,"width":"40%"},
                {"name": "蓄量","codename": "S","tableV":"1","isShow":true,"width":"20%"},
                {"name": "警戒蓄量","codename": "WRZS","tableV":"1","isShow":false,"width":"20%"},
                {"name": "保证蓄量","codename": "GRZS","tableV":"1","isShow":false,"width":"20%"}
             ];
             
             
    lineOption.value=chartSW( strJson,strNote, LineColor, "水位", maxArr, wrzDataS, grzDataS); 
    datekey.value = Date.now();
}
function chartSW( data, strNote, LineColor, max_min_Name, maxArr, wrzDataS, grzDataS) {
            //echarts.init(document.getElementById('quxian'), 'macarons');
            var chartName = []; 	//控件元素名称
            var chartTM = []; 	//时间序列
            var chartValue = []; //时间序列
            var liststr = ""; 	//拼装表格
            var ShowSelected = {};
            var m = new Array();
            $.each(strNote, function (index, value, item) {
                chartName.push(value.name);   //Echarts绘制标注名称加入
                ShowSelected[value.name] = value.isShow;
            });
            //循环数据，加入有效数据。
            $.each(data, function (index, value, item) {
                var charthan = []; 	//时间序列
                $.each(strNote, function (index1, value1, item1) {
                    charthan.push(value[value1.codename]); //加入集合
                    if (value1.name == "时间") {
                        var tm = value[value1.codename];//convertToDate(value[value1.codename]).format("yyyy-MM-dd HH:mm");
                        // if (rbl.getValue() == "DAY") {
                        //     tm = new Date(tm).format("yyyy-MM-dd");
                        // }
                        // else if (rbl.getValue() == "HOUR") {
                            // tm = new Date(tm).format("MM-dd HH");
                            tm=dayjs(tm).format("MM-DD HH")
                        // }
                        chartTM.push(tm); //加入时间集合
                    }
                    else {
                        chartValue.push(value[value1.codename]);
                    }
                });
                m.push(charthan); //加入集合
            });
            //获得最大值最小值
            //var max_min=GetSort(chartValue);
            var titleText = "槽蓄量和平均水位过程";
            var option = {
                // title: {
                //     text: titleText,
                //     textStyle: {
                //         //color: '#497DBB',
                //         color: '#414C59',
                //         // fontSize: 12,
                //         // fontWeight: 'normal'
                //     },
                //     // subtext: subtext,
                //     subtextStyle: {
                //         color: '#497DBB',
                //         fontSize: 16,
                //         fontWeight: 'normal'
                //     },
                //     left: 'center',
                //     top: 0
                // },
                //backgroundColor: '#100E19',
                noDataLoadingOption: {
                    text: '暂无数据',
                    effect: 'bubble',
                    effectOption: {
                        effect: {
                            n: 0 //气泡个数为0
                        }
                    },
                    textStyle: {
                        fontSize: 30,
                        fontWeight: 'bold'
                    }
                },
                tooltip: {
                    showDelay: 0,
                    hideDelay: 50,
                    transitionDuration: 0,
                    backgroundColor: 'rgba(255,255,255,0.9)',
                    borderColor: '#4040FB',
                    borderRadius: 8,
                    borderWidth: 2,
                    padding: 10,
                    textStyle: {
                        color: '#000000'
                    },
                    trigger: 'axis',
                    formatter: function (params, ticket, callback) {
                        var dataIndex = params[0].dataIndex;
                        var dataValue = Number(params[0].data).toFixed(2);
                        var str = "蓄量：" + dataValue + "<br/>";
                        str += "水位：" + Number(data[dataIndex].UPZ).toFixed(2);
                        return str;
                    }
                },
                color: LineColor,
                legend: {
                    data: chartName,
                    show: true,
                    itemWidth: 8,
                    itemHeight: 8,
                    textStyle: {
                        color: '#fff',
                        fontSize: 12
                    },
                    selected: ShowSelected,
                    y: 10,
                },
                grid: {
                    left: '5%',
                    right: '5%',
                    bottom: '3%',
                    top: '20%',
                    containLabel: true
                },
                xAxis: [
                    {
                        type: 'category',
                        boundaryGap: true,
                        data: chartTM,
                        axisLine: {
                            lineStyle: {
                                color: "#00FFFF",
