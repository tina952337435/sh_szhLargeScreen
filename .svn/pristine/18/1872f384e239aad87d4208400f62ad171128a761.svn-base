                    }
                ],
                yAxis: [
                    {
                        name: "(百万方)",
                        type: 'value',
                        boundaryGap: false,
                        // splitNumeber: 5,
                        scale: true, //是否自动计算最大最小值。
                        splitLine: {
                            show: true,
                            lineStyle: {
                                color: "#074159",
                                // width: 1,
                                // type: 'dashed',
                            }
                        },
                        min: 90,
                        min: function (e) {
                            return e.min - 30;
                        },
                        max: function (e) {
                            return e.max + 10;
                        },
                        axisLabel: {
                            formatter: function (v) {
                                // console.error(v);
                                var str = v.toFixed(0);
                                if (v == maxArr[0]) {
                                    str = '';
                                }
                                return str;
                            },
                        },
                        axisLine: {
                            lineStyle: 
                            {
                                color: "#00FFFF",
                                width: 1 //这里是为了突出显示加上的
                            },
                            textStyle: {
                                color: "#00FFFF",
                                fontSize: 14,
                            }
                        },
                    }
                ],
                series: function () {
                    var serie = [];
                    for (var j = 0; j < chartName.length; j++) {
                        if (chartName[j] == "时间") //调过时间字段
                        {
                            continue;
                        }
                        var chartValue = []; 	//声明过线value集合
                        for (var i = 0; i < m.length; i++) {
                            chartValue.push(m[i][j]); //循环价值
                        }
                        if (max_min_Name != "" & max_min_Name == chartName[j]) {
                            var item = {
                                name: chartName[j],
                                type: 'line',
                                data: chartValue,
                                connectNulls: true,
                                markPoint: {
                                    data: [{ type: 'max', name: '最大值' }, { type: 'min', name: '最小值' }]
                                },
                                smooth: true,
                                symbol: 'none',
                            }
                            serie.push(item);
                        }
                        else if (chartName[j] == "蓄量") {
                            var item = {
                                name: chartName[j],
                                type: 'bar',
                                barMaxWidth: '30%',
                                data: chartValue,
                                connectNulls: true,
                                yAxisIndex: 0,
                                smooth: true,
                                symbol: 'none',
                                itemStyle: {
                                    normal: {
                                        color: {
                                            type: 'linear',
                                            x: 0,
                                            y: 0,
                                            x2: 0,
                                            y2: 1,
                                            colorStops: [{
                                                offset: 0,
                                                color: '#2D8DED'
                                            }, {
                                                offset: 1,
                                                color: '#5ED8FB'
                                            }]
                                        },
                                        barBorderRadius: [30, 30, 0, 0],
                                    }
                                },
                                label: {
                                    show: true,
                                    position: 'top',
                                    // offset: [-70, -5],
                                    color: '#000000',
                                    formatter: function (params) {
                                        var str = '';
                                        str += '{bValue|' + Number(data[params.dataIndex].UPZ).toFixed(2) + '}';
                                        // if (chartValue.length <= 50) {
                                        //     if ((params.dataIndex!=0&&params.dataIndex % 5 == 0)|| params.dataIndex == chartValue.length - 1) {
                                        //         str += '蓄量{bValue|' + Number(params.value).toFixed(2) + '}\n';
                                        //         str += '水位{bValue|' + Number(data[params.dataIndex].UPZ).toFixed(2) + '}';
                                        //     }
                                        // }else{
                                        //     if (params.dataIndex == chartValue.length - 1) {
                                        //         str += '蓄量{bValue|' + Number(params.value).toFixed(2) + '}\n';
                                        //         str += '水位{bValue|' + Number(data[params.dataIndex].UPZ).toFixed(2) + '}';
                                        //     }
                                        // }
                                        return str;
                                    },
                                    rich: {
                                        bValue: {
                                            color: "#57CDF9",
                                            fontSize: 13,
                                            // fontWeight: 600,
                                            lineHeight: 22,
                                            align: 'center'
                                        },
                                    }
                                }
                            }
                            serie.push(item);
                        }
                        else {
                            var item = {
                                name: chartName[j],
                                type: 'line',
                                data: chartValue,
                                connectNulls: true,
                                smooth: true,
                                symbol: 'none',
                                symbol: 'circle',  //这句就是去掉点的
                                symbolSize: 0.01,
                                label: {
                                    show: true,
                                    position: 'top',
                                    // offset: [-70, -5],
                                    color: '#000000',
                                    formatter: function (params) {
                                        var str = '';
                                        if (params.dataIndex == chartValue.length - 1) {
                                            var value = "", cls = "";
                                            if (params.seriesName == "警戒蓄量") {
                                                value = Number(data[params.dataIndex].WRZS).toFixed(2);
                                                cls = "wrzValue";
                                            }
                                            if (params.seriesName == "保证蓄量") {
                                                value = Number(data[params.dataIndex].GRZS).toFixed(2);
                                                cls = "grzValue";
                                            }
                                            str += '{' + cls + '|' + value + '}';
                                        }
                                        return str;
                                    },
                                    rich: {
                                        wrzValue: {
                                            color: 'orange',
                                            fontSize: 13,
                                            // fontWeight: 600,
                                            lineHeight: 22,
                                            align: 'center'
                                        },
                                        grzValue: {
                                            color: 'red',
                                            fontSize: 13,
                                            // fontWeight: 600,
                                            lineHeight: 22,
                                            align: 'center'
                                        },
                                    }
                                }
                            }
                            serie.push(item);
                        }
                    };
                    return serie;
                }()
            };
            return option;
        }
</script>