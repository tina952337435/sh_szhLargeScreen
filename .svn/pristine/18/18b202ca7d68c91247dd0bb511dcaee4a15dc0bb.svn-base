.div-swiper {
    line-height: 26px;
    /* margin: 0 auto; */
    margin-left: auto;
}

.swiper-slide {
    background-size: cover;
    background-position: center;
    position: relative;
    width: 25%;
    height: 1.875rem;
    font-size: 0.875rem;
    color: var(--mtablethcolor);
    white-space: nowrap;
    line-height: 2rem;
    text-align: center;
    cursor: pointer;
    background: var(--swiperSlide) no-repeat top center;
    background-size: 100% 1.875rem;
    display: inline-block;
    font-family: arial, "Hiragino Sans GB";
}

.swiper-slide-thumb-active {
    font-size: 0.875rem;
    /* color: var(--mtablethcolor); */
    color: #ffffff;
    background: var(--swiperSlideActive) no-repeat top center;
    background-size: 100% 1.875rem;
}

.dialog .div-swiper {
    line-height: 34px;
    margin: 0 auto;
    max-width: 60%;
}