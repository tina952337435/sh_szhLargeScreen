<template>
    <ul class="toptabTop">
        <li :class="pathname == '南岸' && 'toptabToponlyliHover'" class="toptabToponlyli" @click="getType('南岸')">南岸</li>
        <li :class="pathname == '北岸' && 'toptabToponlyliHover'" class="toptabToponlyli" @click="getType('北岸')">北岸</li>
    </ul>
    <Echarts :width="'100%'" :height="'90%'" :option="lineOption" :key="datekey" id="riverdf" />
</template>
<script setup>
import Echarts from "@/components/MyEcharts/echartsLine.vue";
import ChartJs from "@/api/MyEcharts/ChartJs.js";
import * as echarts from "echarts";
import api from "@/api/zonglan/index.js";
import dayjs from "dayjs";
import $ from "jquery";
import { ref, onMounted, reactive, inject } from "vue";
import { groupBy, SetNull, sortObjectArray } from "@/api/ComUnit";
import tphdikeData from "@/assets/json/TPHDMMXNEW.json"; //太浦河堤防
// 获取当前主题
const _theme = localStorage.getItem("curTheme");
const datekey = ref(null);
const lineOption = ref({});
const tableHeaders = [
    { name: "num", label: "序号" },
    { name: "stnm", label: "站名" },
    { name: "upz", label: "水位(m)" },
    { name: "wrz", label: "警戒水位(m)" },
    { name: "grz", label: "保证水位(m)" },
];
const tableData = ref();
var myData = [];
const pathname = ref("南岸");

function Weacontent() {
    var dataResult = [], tphgcDMResult = [];
    var strNote = [];
    strNote.push({ "name": "0", "codename": "63205300", "tableV": "1", "isShow": true, "width": "20%", "nodename": "河口" });
    strNote.push({ "name": "2.8", "codename": "63205311", "tableV": "1", "isShow": true, "width": "20%", "nodename": "太浦闸" });
    strNote.push({ "name": "15.7", "codename": "63205350", "tableV": "1", "isShow": true, "width": "20%", "nodename": "平望" });
    strNote.push({ "name": "40.3", "codename": "63403200", "tableV": "1", "isShow": true, "width": "20%", "nodename": "金泽" });
    strNote.push({ "name": "53.9", "codename": "63403220", "tableV": "1", "isShow": true, "width": "20%", "nodename": "练塘" });

    var strJson = [
        {
            "STCD": "63205300",
            "UPZ": 3.49,
            "TM": "\\/Date(1755832800000-0000)\\/"
        },
        {
            "STCD": "63205350",
            "UPZ": 3.01,
            "TM": "\\/Date(1755832800000-0000)\\/"
        },
        {
            "STCD": "63403200",
            "UPZ": 2.53,
            "TM": "\\/Date(1755832800000-0000)\\/"
        },
        {
            "STCD": "63403220",
            "UPZ": 2.48,
            "TM": "\\/Date(1755832200000-0000)\\/"
        },
        {
            "STCD": "63205311",
            "UPZ": 3.49,
            "DWZ": 3.04,
            "TM": "\\/Date(1755832800000-0000)\\/"
        },
        {
            "STCD": "63401100",
            "UPZ": 1.91,
            "TM": "\\/Date(1755831600000-0000)\\/"
        }
    ];
    if (SetNull(tphdikeData) != "") {
        var obj;
        if (pathname.value == "南岸") {
            obj = "右岸";
        } else {
            obj = "左岸";
        }
        tphgcDMResult = tphdikeData.filter(function (evt) {
            return evt["NAME"] == obj;
        })
    }

    for (var num = 0; num <= 576; num++) {
        var item = {};
        item["STNM"] = num / 10;
        if (item["STNM"] >= 53.9) {
            //练塘后续水位
            var stcdold = "63403220";
            var result = strJson.filter(function (evt) {
                return evt["STCD"] == stcdold;
            })
            if (result.length > 0) {
                item["UPZ"] = result[0]["UPZ"];
            }
        }
        else if (item["STNM"] >= 40.3) {
            //金泽——练塘
            var stcdold = "63403200";
            var stcd = "63403220";
            var resultold = strJson.filter(function (evt) {
                return evt["STCD"] == stcdold;
            })
            var result = strJson.filter(function (evt) {
                return evt["STCD"] == stcd;
            })
            var upzold = 0, upz = 0;
            var disold = 40.3, dis = 53.9;
            if (resultold.length > 0) {
                upzold = resultold[0]["UPZ"];
            }
            if (result.length > 0) {
                upz = result[0]["UPZ"];
            }
            var cha = (upz - upzold) / ((dis - disold) * 10);
            item["UPZ"] = upzold + (cha * (num - disold * 10));

        }
        else if (item["STNM"] >= 15.7) {
            //平望——金泽
            var stcdold = "63205350";
            var stcd = "63403200";
            var resultold = strJson.filter(function (evt) {
                return evt["STCD"] == stcdold;
            })
            var result = strJson.filter(function (evt) {
                return evt["STCD"] == stcd;
            })
            var upzold = 0, upz = 0;
            var disold = 15.7, dis = 40.3;
            if (resultold.length > 0) {
                upzold = resultold[0]["UPZ"];
            }
            if (result.length > 0) {
                upz = result[0]["UPZ"];
            }
            var cha = (upz - upzold) / ((dis - disold) * 10);
            item["UPZ"] = upzold + (cha * (num - disold * 10));
        }
        else if (item["STNM"] >= 2.8) {
            //太浦闸——平望
            var stcdold = "63205311";
            var stcd = "63205350";
            var resultold = strJson.filter(function (evt) {
                return evt["STCD"] == stcdold;
            })
            var result = strJson.filter(function (evt) {
                return evt["STCD"] == stcd;
            })
            var upzold = 0, upz = 0;
            var disold = 2.8, dis = 15.7;
            if (resultold.length > 0) {
                upzold = resultold[0]["UPZ"];
            }
            if (result.length > 0) {
                upz = result[0]["UPZ"];
            }
            var cha = (upz - upzold) / ((dis - disold) * 10);
            item["UPZ"] = upzold + (cha * (num - disold * 10));
        }
        else {
            //河口——太浦闸
            var stcdold = "63205300";
            var stcd = "63205311";
            var resultold = strJson.filter(function (evt) {
                return evt["STCD"] == stcdold;
            })
            var result = strJson.filter(function (evt) {
                return evt["STCD"] == stcd;
            })
            var upzold = 0, upz = 0;
            var disold = 0, dis = 2.8;
            if (resultold.length > 0) {
                upzold = resultold[0]["UPZ"];
            }
            if (result.length > 0) {
                upz = result[0]["UPZ"];
            }
            var cha = (upz - upzold) / ((dis - disold) * 10);
            item["UPZ"] = upzold + (cha * (num - disold * 10));

        }
        dataResult.push(item);
    }

    var listResultData = [];
    if (dataResult.length > 0) {
        var strWhere = {};
        strWhere["STNM"] = "0";
        for (var num = 0; num < dataResult.length; num++) {
            // console.error("dataResult", dataResult[num]);
            var item = dataResult[num];
            strWhere = {};
            strWhere["STNM"] = item["STNM"];
            strWhere["UPZ"] = item["UPZ"];
            console.error("tphgcDMResult",tphgcDMResult)
            var oneList = sortObjectArray(tphgcDMResult.filter(function (item) {
                return Number(Number(item["DIS"]).toFixed(1)) <= Number(strWhere["STNM"]);
            }), ["DIS"], "desc");
            if (oneList.length > 0) {
                var oneGCList = oneList.filter(function (ett) {
                    return ett["TYPEID"] == "高程";
                })
                var oneQKList = oneList.filter(function (ett) {
                    return ett["TYPEID"] == "青坎";
                })
                console.error("oneGCList", oneGCList)
                if (oneGCList.length > 0) {
                    strWhere["GC"] = SetNull(oneGCList && oneGCList.length > 0 ? oneGCList[0]["VAL"] : null);
                    strWhere["DIS"] = oneGCList[0]["DIS"];
                    strWhere["STTP"] = SetNull(oneGCList && oneGCList.length > 0 ? oneGCList[0]["STTP"] : null);

                }
                if (oneQKList.length > 0) {
                    strWhere["QKAN"] = oneQKList[0]["VAL"];
                    strWhere["DIS"] = oneQKList[0]["DIS"];
                    strWhere["STTP"] = SetNull(oneQKList && oneQKList.length > 0 ? oneQKList[0]["STTP"] : null);
                }
            }
            listResultData.push(strWhere);
        }
    }
    var noteResult = [
        { "name": "时间", "codename": "STNM", "tableV": "1", "isShow": true, "width": "20%" },
        { "name": "水位", "codename": "UPZ", "tableV": "1", "isShow": true, "width": "20%" },
        { "name": "堤顶高程", "codename": "GC", "tableV": "1", "isShow": true, "width": "20%" },
        { "name": "青坎", "codename": "QKAN", "tableV": "1", "isShow": true, "width": "20%" }
    ];
    if (strJson.length > 0) {
        for (var num = 0; num < strJson.length; num++) {
            var item = strJson[num];
            if (item["STCD"] == "63205311") {
                noteResult.push({ "name": "太浦闸:" + item["UPZ"] + "m", "codename": "UPZ", "tableV": "2", "isShow": true, "width": "20%" })
            }
            else if (item["STCD"] == "63205300") {
                noteResult.push({ "name": "太浦河口:" + item["UPZ"] + "m", "codename": "UPZ", "tableV": "2", "isShow": true, "width": "20%" })
            }
            else if (item["STCD"] == "63205350") {
                noteResult.push({ "name": "平望:" + item["UPZ"] + "m", "codename": "UPZ", "tableV": "2", "isShow": true, "width": "20%" })
            }
            else if (item["STCD"] == "63403200") {
                noteResult.push({ "name": "金泽:" + item["UPZ"] + "m", "codename": "UPZ", "tableV": "2", "isShow": true, "width": "20%" })
            }
            else if (item["STCD"] == "63403220") {
                noteResult.push({ "name": "练塘:" + item["UPZ"] + "m", "codename": "UPZ", "tableV": "2", "isShow": true, "width": "20%" })
            }
        }
    }
    var LineColor = ["#F9F900", "#8E9293", "yellw"];
    var barImage = 'data:image/png;base64,'
    var minGCImage = 'data:image/png;base64,'

    const _Option = ChartJs.chartSWDM("", listResultData, noteResult, LineColor, "水位(m)", _theme, barImage, minGCImage);
    lineOption.value = _Option;
    datekey.value = Date.now();
}
onMounted(() => {
    Weacontent();
});
function getType(obj) {
    pathname.value = obj;
    Weacontent();
}
</script>
<style scoped>
.toptabTop {
    list-style: none;
    color: #00feff;
    border-color: #00feff;
    width: auto !important;
    /* display: inline; */
    /* position: relative; */
    left: 0px;
    bottom: 0px;
    top: 5px;
    padding: 0px;
    display: inline-block;
    vertical-align: -12px;
}

.toptabToponlyli {
    float: left;
    height: 32px;
    width: 40px;
    text-align: center;
    line-height: 32px;
    cursor: pointer;
    background-color: var(--portal);
    border: 1px solid var(--portal);
    color: var(--sel_wraplabelcolor);
}

.toptabTop li:first-child {
    border-radius: 5px 0 0 5px;
}

.toptabTop li:last-child {
    border-radius: 0 5px 5px 0;
}

.toptabToponlyliHover {
    background-color: var(--swDivSelectcolor);
    border: 1px solid var(--swDivSelectcolor);
    color: var(--sel_wraplabelcolorSel);
}
</style>
  