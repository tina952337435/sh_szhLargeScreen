  var strJson = res.result;
  var result = [];
  var wrzCount = 0, zcCount = 0;
  if (strJson.length > 0) {
    for (var num = 0; num < strJson.length; num++) {
      var item = strJson[num];
      var upz = SetNull(item.upz) != "" ? Number(item.upz).toFixed(2) : "—";
      var maxUpz = SetNull(item.maxUpz) != "" ? Number(item.maxUpz).toFixed(2) : "—";
      var totalQ = SetNull(item.pumcap) != "" ? Number(item.pumcap).toFixed(2) : 0;; //总流量
      var indexQ = SetNull(item.q) != "" ? Number(item.q).toFixed(2) : 0;//当前开机流量
      var value = indexQ > 0 ? (Number(indexQ) / (totalQ) * 100) : indexQ;
      var colorCss = "";
      var valWrz = 0;
      if (maxUpz != "—" && upz != "—") {
        valWrz = Number(upz) - Number(maxUpz);
      }

      if (valWrz > 0) {
        wrzCount++;
        colorCss = "#FFC000";
      } else if (upz != "—") {
        zcCount++;
        // colorCss = "#34B70E"
      } else {
        colorCss = "#C0C0C0"
      }
      var _strParam = {};
      _strParam["wqname"] = item.wqname;
      _strParam["upz"] = upz;
      _strParam["indexQ"] = indexQ;
      _strParam["paiBili"] = value;
      _strParam["wqid"] = item.wqid;
      _strParam["colorCss"] = colorCss;
      _strParam["rainList"] = item.rainList;
      _strParam["maxUpz"] = item.maxUpz;  //控制水位
      _strParam["wq_zhen"] = item.wq_zhen;
      _strParam["lgtd"] = item.lgtd;
      _strParam["lttd"] = item.lttd;

      result.push(_strParam);
      WQtableDataAll.value = result;
      $.data(myData, "WQtableDataAll", result);
      datekeyAll.value = dayjs(dayjs(Date.now()).format("YYYY-MM-DD HH:mm:ss")).add(6, "hour").format("YYYY-MM-DD HH:mm:ss");
    }
    if (WQtableDataAll.value.length > 0) {
      addWQMark();
    }
  }
  // }).catch((err) => { });
  // window.loadingHide();
}
