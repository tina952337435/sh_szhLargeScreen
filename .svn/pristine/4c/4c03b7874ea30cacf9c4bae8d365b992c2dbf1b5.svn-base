<template>
  <table>
    <thead>
      <tr>
        <th v-for="header in headers" :key="header">{{ header.label }}</th>
      </tr>
    </thead>
    <tbody>
      <tr v-for="(row, rowIndex) in rows" :key="row.id">
        <td v-for="(cell, cellIndex) in headers" :key="cellIndex"
          :style="{ color: '' + (SetNull(row.colorCss) == '' ? '' : row.colorCss) + '!important' }">
          <!-- 如果单元格是图像URL，则显示图像 -->
          <span v-if="cell['name'] === 'imageUrls'">
            <img v-if="row.imageUrls == '/images/ddzh2.png'" src="/images/ddzh2.png" alt="查看圩区推荐预案" />
            <img v-else-if="row.imageUrls != '—'" v-for="(url, index) in row.imageUrls" :key="index" :src="url"
              alt="Image" />
            <span v-else>—</span>
          </span>
          <!-- 响应显示图片 -->
          <span v-else-if="cell['name'] === 'message'" style="cursor: pointer;" @click="getMeaaage(row)">
            <div>
              <img :src="messageIamge" style="width: 24px;height:24px;" />
            </div>
          </span>
          <!-- 显示百分比 -->
          <span v-else-if="cell['name'] === 'paiBili'" style="cursor: pointer;">
            <div class="progress-container">
              <!-- <div class="progress-bar" :style="{
                width: `${Number(row[cell.name])}%`, background: `hsl(${Number(row[cell.name]) * 1.2}, 100%, 50%)`
              }"> -->
              <div class="progress-bar" :style="{
                width: `${Number(row[cell.name])}%`, background: `#00A3FE`
              }">
                <div class="progress-text" style="color: var(--mtablecolor) !important;">
                  <span style="padding-left: 20px;">{{ Number(row[cell.name]).toFixed(0) }}</span>
                  <span v-if="Number(row[cell.name]) > 20" style="font-size: 12px;">%</span>
                  <span v-else style="font-size: 12px;">%</span>
                </div>
                <!-- <div class="progress-text" v-if="Number(row[cell.name]) > 5"
                  style="color: var(--mtablecolor) !important;">
                  <span style="padding-left: 20px;">{{ Number(row[cell.name]).toFixed(0) }}</span>
                  <span v-if="Number(row[cell.name]) > 20" style="font-size: 12px;">%</span>
                  <span v-else style="font-size: 12px;color:#fff;">%</span>
                </div>
                <div class="progress-text" v-else>
                  <span style="padding-left: 20px;">{{ Number(row[cell.name]).toFixed(0) }}</span>
                  <span style="font-size: 12px;color:#fff;">%</span>
                </div> -->
              </div>
            </div>
          </span>
          <!-- 如果值为 NaN，则显示 - -->
          <span v-else-if="row[cell.name] === 'NaN'" title="-">-</span>
          <!-- 显示普通文本 -->
          <span v-else :style="'' + (SetNull(row.colorCss) == '' ? JSON.stringify(rowIndex) : row.colorCss) + ''"
            :title="row[cell['name']]">{{ row[cell["name"]] }}</span>
        </td>
      </tr>
    </tbody>
  </table>
</template>

<script setup>
import MyDialog from "@/components/ComDialog.vue";
import { SetNull } from "@/api/ComUnit";
import { ref, onMounted, provide } from "vue";
const tableWidth = ref(0);
const tableHeight = ref(300); // 假设表格高度是300px
const props = defineProps({
  headers: {
    type: Array,
    required: true,
  },
  rows: {
    type: Array,
    required: true,
  },
});
// 判断弹窗是否显示,默认隐藏
const showDialog = ref(false);
const titleName = ref('');
const typeValue = ref('');
// 获取当前主题
const _theme = localStorage.getItem("curTheme");
const messageIamge = ref('/images/qxjz/message_default.png')

function isImageUrl(cell) {
  // 简单的检查，判断是否是图像URL
  return /\.(png|jpg|jpeg|gif|png|svg|img)$/i.test(cell);
}

function getMeaaage(row) {
  showDialog.value = true;
  titleName.value = row.showTypeName + "短信通知"
  typeValue.value = row;
}

// 提供方法给子组件
provide("typeValue", typeValue);

onMounted(() => {
  if (_theme == "default") {
    messageIamge.value = '/images/qxjz/message_default.png';
  } else if (_theme == "BlueTheme") {
    messageIamge.value = '/images/qxjz/message_BlueTheme.png';
  } else if (_theme == "VioletTheme") {
    messageIamge.value = '/images/qxjz/message_VioletTheme.png';
  }
});
</script>
