import request from "@/utils/request";
const serveName = ''
export default {
  // 获取用户权限
  getUsePremission: (params) => {
    return request.get('/getUsePremission', params)
  },
  // 用户登录
  useLogin: (params) => {
    return request.post(`${serveName}sysEmployee/LOGINSel`, params)
  },
  //统一用户：获取token信息
  getUserToken: () => {
    var params={
      "stUsername": "wavenet",
      "stPassword": "n0MQDLBsOSqim25mBN5m/g=="
    };
    return request.post(`${serveName}/system/sso/login`, params)
  },
  //统一用户：获取用户基础信息
  getvHyUserlist: (params) => {
    return request.post(`${serveName}/vHyUserlist/list`, params)
  },
}
