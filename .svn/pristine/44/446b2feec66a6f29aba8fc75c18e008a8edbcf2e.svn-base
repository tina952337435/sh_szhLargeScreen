.m-table {
  width: 94%;
  /* table-layout: fixed; */
  margin-top: 0rem;
  margin: 0 auto;
  /* 表格里面显示省略号必须加fixed，td设置的宽度会失效，宽度限定写在th中*/
}

.m-table tr {
  height: 38px;
  line-height: 38px;
  display: flex;
}

.m-table tr:nth-child(even) td {
  background: var(--mtabletrcolor);
}

.m-table tr th {
  font-size: 0.8rem;
  color: var(--popupContentTitleColor);
  font-weight: bold;
  height: 2.1rem;
  text-align: center;
  flex: 1;
}

.m-table tr td {
  /* height: 1.6rem; */
  font-size: 14px;
  text-align: center;
  /* min-width: 80px; */
  flex: 1;
  cursor: pointer;
  color: var(--mtablecolor) !important;
}

.m-table tr td:nth-child(1) {
  color: var(--mtablecolor) !important;
  /*font-family: number;*/
}

.m-table tr td:nth-child(2) {
  color: var(--mtablecolor) !important;
  /*font-family: number;*/
}

.m-table tr td:nth-child(3) {
  color: var(--mtablecolor) !important;
  /*font-family: number;*/
}

.m-table tr td:nth-child(4) {
  color: var(--mtablecolor) !important;
  /*font-family: number;*/
}

.m-table tr td:nth-child(5) {
  color: var(--mtablecolor) !important;
  /*font-family: number;*/
}

.m-table .trSelect {
  background: rgba(0, 255, 255, 0.5) !important;
}

/* 重写el-table样式 */
.el-table {
  background-color: var(--el-table-bg-colornew);
}


/* 地图单站弹出表格 */
.tableYQ {
  flex-direction: column;
  height: 100%;
  position: relative;
  display: flex;
  width: 100%;
  /* table-layout: fixed; */
  margin-top: 0rem;
  margin: 0 auto;
  /* 表格里面显示省略号必须加fixed，td设置的宽度会失效，宽度限定写在th中*/
}


.tableYQ tr th {
  font-size: 0.8rem;
  color: var(--popupContentTitleColor) !important;
  /* background: var(--mtabletrcolor) !important; */
  font-weight: bold;
  height: 2.1rem;
  text-align: center;
  flex: 1;
}

.tableYQ tr td {
  color: var(--widgetcolor);
  height: 1.6rem;
  font-size: 14px;
  text-align: center;
  height: 38px;
  line-height: 38px;
  flex: 1;
}