  $("#XCQPATH").attr("fill", color[0]);
  $("#XCQTXT").attr("fill", color[1]);

  $("#GSQ").html(gsq);
  color = getRainColor(gsq).split("@");
  $("#GSQ").css("color", color[1]);
  $("#GSQPATH").attr("fill", color[0]);
  $("#GSQTXT").attr("fill", color[1]);

  $("#HQQ").html(hqq);
  color = getRainColor(hqq).split("@");
  $("#HQQ").css("color", color[1]);
  $("#HQQPATH").attr("fill", color[0]);
  $("#HQQTXT").attr("fill", color[1]);

  $("#WZQ").html(wzq);
  color = getRainColor(wzq).split("@");
  $("#WZQ").css("color", color[1]);
  $("#WZQPATH").attr("fill", color[0]);
  $("#WZQTXT").attr("fill", color[1]);

  $("#WJQ").html(wjq);
  color = getRainColor(wjq).split("@");
  $("#WJQ").css("color", color[1]);
  $("#WJQPATH").attr("fill", color[0]);
  $("#WJQTXT").attr("fill", color[1]);
  if (isStop == false) {
    areastartCount();
  }
}
function ylHtmlDay(day) {
  var data = $.data(myData, "ybData");
  var stime = convertToDate(data[0].TM);
  stime = $.data(myData, "YBTM");
  // var etime = addDayDate(stime, day);
  var etime = dayjs(dayjs(stime).format("YYYY-MM-DD HH:mm:ss"))
    .add(+(day), "DAY")
    .format("YYYY-MM-DD HH:mm:ss");
  var dataTemp = data.filter(function (e) {
    return (
      dayjs(convertToDate(e.TM)).format("YYYY-MM-DD HH:mm:ss") >= stime &&
      dayjs(convertToDate(e.TM)).format("YYYY-MM-DD HH:mm:ss") <=
      dayjs(new Date(etime)).format("YYYY-MM-DD  08:00:00")
    );
  });
  // console.error("ylHtmlDay", dayjs(new Date(etime)).format("YYYY-MM-DD HH:mm:ss"))

  var title =
    dayjs(new Date(stime)).format("M月D日H时") +
    "—" +
    dayjs(new Date(etime)).format("M月D日H时");
  title +=
    "<br/><span style='color:white;font-size:15px;'>(" +
    dayjs(new Date($.data(myData, "YBTM"))).format("M月D日HH时") +
    "发布)</span>";
  $(".qxTitleCon").html(title);
  var zjgs = 0,
    css = 0,
    tcs = 0,
    kss = 0,
    xcq = 0,
    gsq = 0,
    hqq = 0,
    wzq = 0,
    wjq = 0;
  var arrayList = [];
  for (var obj of dataTemp) {
    if (obj["张家港"] != undefined) {
      zjgs += obj["张家港"];
    }
    if (obj["常熟"] != undefined) {
      css += obj["常熟"];
    }
    if (obj["太仓"] != undefined) {
      tcs += obj["太仓"];
    }
    if (obj["昆山"] != undefined) {
      kss += obj["昆山"];
    }
    if (obj["昆山"] != undefined) {
      hqq += obj["昆山"];
    }
    if (obj["昆山"] != undefined) {
      gsq += obj["昆山"];
    }
    if (obj["常熟"] != undefined) {
      xcq += obj["常熟"];
    }
    if (obj["吴江"] != undefined) {
      wzq += obj["吴江"];
    }
    if (obj["吴江"] != undefined) {
      wjq += obj["吴江"];
    }
  }

  zjgs = zjgs.toFixed(1);
  css = css.toFixed(1);
  tcs = tcs.toFixed(1);
  kss = kss.toFixed(1);
  xcq = xcq.toFixed(1);
  gsq = gsq.toFixed(1);
  hqq = hqq.toFixed(1);
  wzq = wzq.toFixed(1);
  wjq = wjq.toFixed(1);

  $("#ZJGS").html(zjgs);
  var color = getRainColor(zjgs).split("@");
  $("#ZJGS").css("color", color[1]);
  $("#ZJGSPATH").attr("fill", color[0]);
  $("#ZJGSTXT").attr("fill", color[1]);

  $("#CSS").html(css);
  color = getRainColor(css).split("@");
  $("#CSS").css("color", color[1]);
  $("#CSSPATH").attr("fill", color[0]);
  $("#CSSTXT").attr("fill", color[1]);

  $("#TCS").html(tcs);
  color = getRainColor(tcs).split("@");
  $("#TCS").css("color", color[1]);
  $("#TCSPATH").attr("fill", color[0]);
  $("#TCSTXT").attr("fill", color[1]);

  $("#KSS").html(kss);
  color = getRainColor(kss).split("@");
  $("#KSS").css("color", color[1]);
  $("#KSSPATH").attr("fill", color[0]);
  $("#KSSTXT").attr("fill", color[1]);

  $("#XCQ").html(xcq);
  color = getRainColor(xcq).split("@");
  $("#XCQ").css("color", color[1]);
  $("#XCQPATH").attr("fill", color[0]);
  $("#XCQTXT").attr("fill", color[1]);

  $("#GSQ").html(gsq);
  color = getRainColor(gsq).split("@");
  $("#GSQ").css("color", color[1]);
  $("#GSQPATH").attr("fill", color[0]);
  $("#GSQTXT").attr("fill", color[1]);

  $("#HQQ").html(hqq);
  color = getRainColor(hqq).split("@");
  $("#HQQ").css("color", color[1]);
  $("#HQQPATH").attr("fill", color[0]);
  $("#HQQTXT").attr("fill", color[1]);

  $("#WZQ").html(wzq);
  color = getRainColor(wzq).split("@");
  $("#WZQ").css("color", color[1]);
  $("#WZQPATH").attr("fill", color[0]);
  $("#WZQTXT").attr("fill", color[1]);

  $("#WJQ").html(wjq);
  color = getRainColor(wjq).split("@");
  $("#WJQ").css("color", color[1]);
  $("#WJQPATH").attr("fill", color[0]);
  $("#WJQTXT").attr("fill", color[1]);
  if (isStop == false) {
    areastartCount();
  }
}
//根据降雨值分颜色
function getRainColor(value) {
  value = Number(value);
  var color = "rgba(10,18,51)";
  var txtColor = "#ffffff";
  if (value > 0 && value < 10) {
    color = "#A7F387";
    txtColor = "#ffffff";
  } else if (value >= 10 && value < 25) {
    color = "#39BC39";
    txtColor = "#ffffff";
  } else if (value >= 25 && value < 50) {
    color = "#62B7FE";
    txtColor = "#ffffff";
  } else if (value >= 50 && value < 100) {
    color = "#0004F6";
    txtColor = "#ffffff";
  } else if (value >= 100 && value < 250) {
    color = "#F801FA";
    txtColor = "#ffffff";
  } else if (value >= 250) {
    color = "#800140";
    txtColor = "#ffffff";
  }
  return color + "@" + txtColor;
}
//拖拽时间

function dragnew() {
  var odrag = document.getElementById("slide_btn");
  odrag.onmousedown = function (ev) {
    var oevent = ev || event;
    var distanceX = oevent.clientX - odrag.offsetLeft;
    var distanceY = oevent.clientY - odrag.offsetTop;
    var old_x = oevent.clientX;
    var old_y = oevent.clientY;
    var _count = 0;
    document.onmousemove = function (ev) {
      var oevent = ev || event;
      var _x, _y;
      _x = oevent.clientX - distanceX;
      _y = oevent.clientY - distanceY;
      if (_x < 0) _x = 0;
      if (_y < 0) _y = 0;
      if (_x > document.body.clientWidth - odrag.offsetWidth)
        _x = document.body.clientWidth - odrag.offsetWidth;
      if (_y > document.body.clientHeight - odrag.offsetHeight)
        _y = document.body.clientHeight - odrag.offsetHeight;
      if (_x > slide_btn_len) {
        _x = slide_btn_len;
      }
      odrag.style.left = _x + "px";
      _count++;
      // odrag.style.top = _y + 'px';
    };
    document.onmouseup = function (ev) {
      var oevent = ev || event;
      var _x = oevent.clientX - distanceX;
      var _y = oevent.clientY - distanceY;
      var leftindex = (_x / $("body").width()).toFixed(2);
      var topindex = (_y / $("body").height()).toFixed(2);
      //存储位置区域比列或者具体数据
      document.onmousemove = null;
      document.onmouseup = null;

      var data = $.data(myData, "ybData");
      var total = data.length;
      // var _index = parseInt( _x / total);
      var oneLen = slide_btn_len / total;
      ybIndex = parseInt(_x / oneLen);
      ybIndex = ybIndex;
      ylHtml();
    };
  };
}
</script>
