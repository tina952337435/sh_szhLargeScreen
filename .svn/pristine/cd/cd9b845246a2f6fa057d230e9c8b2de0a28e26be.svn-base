    gsq = dataTemp["姑苏"] != undefined ? dataTemp["姑苏"] : 0,//姑苏
    hqq = dataTemp["虎丘"] != undefined ? dataTemp["虎丘"] : 0,//虎丘区
    wzq = dataTemp["吴江"] != undefined ? dataTemp["吴江"] : 0,//吴中区
    wjq = dataTemp["吴江"] != undefined ? dataTemp["吴江"] : 0
