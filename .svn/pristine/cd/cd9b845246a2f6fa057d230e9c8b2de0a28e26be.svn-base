function WindowOpen(type, ereaname) {
  const props = {};
  props["type"] = type;
  props["ereaname"] = ereaname;
  props["ybtm"] = $.data(myData, "YBTM");
  //ChildVue为弹窗中嵌入的slot
  const ChildVue = defineAsyncComponent(() =>
    import("@/components/danzhan/qx/FQYQLine.vue")
  );
  Dialog.open({ title: ereaname + "预报降雨过程", widh: 1200, heig: 650 }, h(ChildVue, props)).then(() => { console.log('弹窗关闭了') })
}
//设置icon的大小和颜色
defineProps({
  size: {
    type: String,
    default: "30px",
  },
  color: {
    type: String,
    default: "#fff",
  },
});
var curDate;
function loadAreaRain() {
  var hour = new Date().getHours();
  var YBTM = "";
  if (hour >= 21) {
    YBTM = dayjs(new Date()).format("YYYY-MM-DD 20:00:00");
  } else if (hour >= 14) {
    YBTM = dayjs(new Date()).format("YYYY-MM-DD 12:00:00");
  } else if (hour >= 9) {
    YBTM = dayjs(new Date()).format("YYYY-MM-DD 08:00:00");
  } else {
    YBTM = dayjs(new Date())
      .add(-1, "day")
      .format("YYYY-MM-DD HH:mm:ss");
  }
  fabuDate = YBTM;
  $.data(myData, "YBTM", YBTM);
  // var strWhere = {
  //   YBTM: YBTM
  // };

  var startDate = YBTM;
  var endDate = dayjs(startDate).format("YYYY-MM-DD 23:59:59");
  var strWhere = {};
  // strWhere["YBSTIME"] = startDate;
  // strWhere["YBETIME"] = endDate;
  strWhere["PageSize"] = 1;
  strWhere["PageIndex"] = 0;
  strWhere["STCD"] = "32050000,32058300,32058100,32058500,32058200,32050900";
  apiqixiang.RainWeacontent(strWhere).then(res => {
    JosnSel(res, "Tba_JyYb_DtFirst");
  });
}

function JosnSel(data, typeID) {
  if (typeID == "Tba_JyYb_Dt") {
    var dataResult = data.data;
    var dataResultG = groupBy(dataResult, "TM");
    console.error('dataResultG');
    var dataResultNew = [];
    var strHtml = "<ul>";
    for (var num = 0; num < dataResultG.length; num++) {
      strHtml +=
        "<li id='img" +
        (num) +
        "' style='width:" +
        100 / dataResultG.length +
        "%;'>&nbsp;</li>";

      var result = dataResultG[num];
      var tmStr = convertToDate(result[0].TM);
      tmStr = dayjs(tmStr).format("YYYY-MM-DD HH:mm:ss")
      var ybtmStr = convertToDate(result[0].YBTM);
      ybtmStr = dayjs(ybtmStr).format("YYYY-MM-DD HH:mm:ss")
      var itemObj = {
        TM: tmStr,
        YBTM: ybtmStr,
      };
      result.forEach(element => {
        itemObj[element.NAME] = element.DRP;
      });
      dataResultNew.push(itemObj);
    }
    strHtml += "</ul>";
    $("#sld").html(strHtml);
    $.data(myData, "ybData", dataResultNew);
    console.error('dataResultNew', dataResultNew);

    $("#sld ul li").click(function (e) {
      var html = Number(
        $(this)
          .attr("id")
          .replace("img", "")
      );
      isStop = true; //不让自动播放了
      ybIndex = html;
      ylHtml();
    });

    if (dataResult != "") {
      ylHtml();
    } else {
      ShowMsg("无预报降雨！");
    }
    dragnew();
  }
  else if (typeID == "Tba_JyYb_DtFirst") {
    var ybtmStr = convertToDate(data.data[0].YBTM);
    ybtmStr = dayjs(ybtmStr).format("YYYY-MM-DD HH:mm:ss");
    $.data(myData, "YBTM", ybtmStr);
    var strWhere = { YBTM: ybtmStr };
    apiqixiang.RainWeacontentDay(strWhere).then(res => {
      JosnSel(res, "Tba_JyYb_Dt");
    });
  }
}
var t;
var ImgHour = 3000; //播放频率
function areastartCount() {
  t = setTimeout(function () {
    TimeShowYTArea();
  }, ImgHour);
}
function areastopCount() {
  if (t) {
    clearInterval(t);
  }
}
function TimeShowYTArea() {
  var data = $.data(myData, "ybData");
  var total = data.length;
  ybIndex = ybIndex + 1;
