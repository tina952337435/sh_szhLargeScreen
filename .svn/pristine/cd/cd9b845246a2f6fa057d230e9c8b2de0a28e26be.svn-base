function addObjClick() {
  $("#playarea_btn").click(function () {
    isStop = true;
    areastopCount();
    var dis = $(this).css("display");
    if (dis == "none") {
      $(this).css("display", "block");
      $("#playarea_btn1").css("display", "none");
    } else {
      $(this).css("display", "none");
      $("#playarea_btn1").css("display", "block");
    }
  });
  $("#playarea_btn1").click(function () {
    isStop = false;
    areastartCount();
    var dis = $(this).css("display");
    if (dis == "none") {
      $(this).css("display", "block");
      $("#playarea_btn").css("display", "none");
    } else {
      $(this).css("display", "none");
      $("#playarea_btn").css("display", "block");
    }
  });
  $(".imgArea1").click(function () {
    if (ybIndex > 0) {
      ybIndex--;
      ylHtml();
    }
  });
  $(".imgArea2").click(function () {
    if ($.data(myData, "ybData") != null) {
      if (ybIndex < $.data(myData, "ybData").length - 1) {
        ybIndex++;
        ylHtml();
      } else {
        ybIndex = 0;
        ylHtml();
      }
    }
  });
  $(".dayYL li").click(function () {
    $(".dayYL li").removeClass("selected");
    $(this).addClass("selected");
    $(".bofangArea").show();
    $(".imgArea1").show();
    $(".imgArea2").show();
    var html = $(this).html();
    if (html == "逐日") {
      areastartCount();
      ylHtml();
    } else {
      isStop = true;
      areastopCount();
      $(".bofangArea").hide();
      $(".imgArea1").hide();
      $(".imgArea2").hide();
      html = Number(html.replace("日", ""));
      ylHtmlDay(html);
    }
  });

  $("#ZJGSPATH,#ZJGSTXT").click(function (e) {
    WindowOpen("张家港", "张家港市");
  });
  $("#CSSPATH,#CSSTXT").click(function (e) {
    WindowOpen("常熟", "常熟市");
  });
  $("#TCSPATH,#TCSTXT").click(function (e) {
    WindowOpen("太仓", "太仓市");
  });
  $("#XCQPATH,#XCQTXT").click(function (e) {
    WindowOpen("常熟", "相城区");
  });
  $("#KSSPATH,#KSSTXT").click(function (e) {
    WindowOpen("昆山", "昆山市");
  });
  $("#HQQPATH,#HQQTXT").click(function (e) {
    WindowOpen("昆山", "虎丘区");
  });
  $("#GSQPATH,#GSQTXT").click(function (e) {
    WindowOpen("昆山", "姑苏区");
  });
  $("#WZQPATH,#WZQTXT").click(function (e) {
