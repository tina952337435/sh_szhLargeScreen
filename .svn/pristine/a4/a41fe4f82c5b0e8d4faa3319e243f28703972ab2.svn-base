        const markAreas = [];

        // 生成模拟数据逻辑
        let isTopoStart = false;
        let startIndex = 0;

        for (let i = 0; i < dataPoints; i++) {
            // 外江：大潮 + 风暴增水
            const outerVal =outerRiver[i]; //3.8 + 1.2 * Math.sin(i * 0.25) + (i > 15 && i < 35 ? 0.5 : 0); 
            // outerRiver.push(parseFloat(outerVal.toFixed(2)));

            // 内河：滞后响应 + 降雨抬升
            const innerVal =innerRiver[i]; //3.0 + 0.6 * Math.sin(i * 0.25 - 0.8) + (i > 10 && i < 40 ? 0.8 : 0);
            // innerRiver.push(parseFloat(innerVal.toFixed(2)));

            // 计算顶托区间 (外江 > 内河)
            const isTopo = outerVal > innerVal;
            if (isTopo && !isTopoStart) {
                isTopoStart = true;
                startIndex = i;
            } else if (!isTopo && isTopoStart) {
                isTopoStart = false;
                markAreas.push([{ xAxis: startIndex }, { xAxis: i }]);
            }
        }
        if (isTopoStart) markAreas.push([{ xAxis: startIndex }, { xAxis: dataPoints - 1 }]);

        const optionTide = {
            tooltip: {
                trigger: 'axis',
                backgroundColor: 'rgba(0,0,0,0.8)',
                borderColor: '#00ffff',
                textStyle: { color: '#fff' },
                formatter: (p) => {
                    const o = p[0].value, i = p[1].value;
                    const status = o > i ? '<span style="color:red;font-weight:bold">⚠️ 顶托中</span>' : '<span style="color:#0f0">正常</span>';
                    return `${p[0].name}<br/>外江: ${o}m<br/>内河: ${i}m<br/>状态: ${status}`;
                }
            },
            legend: { data: ['吴淞口', '黄浦公园'], textStyle: { color: '#ccc' }, top: 0 },
            grid: { left: '10%', right: '10%', bottom: '15%', top: '20%' },
            xAxis: {
                type: 'category',
                data: labels,
                axisLine: { lineStyle: { color: '#555' } },
                axisLabel: { color: '#00E2E5', rotate: 45 }
            },
            yAxis: [
                {
                    type: 'value',
                    name: '外江 (m)',
                    nameTextStyle: { color: '#00ffff' },
                    axisLabel: { color: '#00ffff' },
                    splitLine: { lineStyle: { color: '#306077', type: 'dashed' } },
                    // min: 2,
                     max: 6
                },
                {
                    type: 'value',
                    name: '内河 (m)',
                    nameTextStyle: { color: '#ffaa00' },
                    axisLabel: { color: '#ffaa00' },
                    splitLine: { show: false },
                    // min: 2, 
                    max: 6
                }
            ],
            series: [
                {
                    name: '吴淞口',
                    type: 'line',
                    smooth: true,
                    data: outerRiver,
                    lineStyle: { width: 2, color: '#00ffff' },
                    areaStyle: { color: new echarts.graphic.LinearGradient(0,0,0,1, [{offset:0,color:'rgba(0,255,255,0.3)'},{offset:1,color:'rgba(0,255,255,0)'}]) }
                },
                {
                    name: '黄浦公园',
                    type: 'line',
                    yAxisIndex: 1,
                    smooth: true,
                    data: innerRiver,
                    lineStyle: { width: 2, color: '#ffaa00' },
                    areaStyle: { color: new echarts.graphic.LinearGradient(0,0,0,1, [{offset:0,color:'rgba(255,170,0,0.3)'},{offset:1,color:'rgba(255,170,0,0)'}]) }
                }
            ],
            markArea: {
                silent: true,
                itemStyle: { color: 'rgba(255, 0, 0, 0.25)', borderColor: 'rgba(255,0,0,0.6)' },
                label: { show: true, position: 'insideTopLeft', color: '#ff4444', fontWeight: 'bold', formatter: '⚠️ 顶托效应区' },
                data: markAreas
            }
        };
    lineOption.value = optionTide;
    datekey.value = new Date();
}
</script>