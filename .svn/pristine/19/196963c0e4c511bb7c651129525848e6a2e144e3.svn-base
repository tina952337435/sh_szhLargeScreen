<template>
    <div class="topClass">
        <!-- <ul class="toptabTop">
      <li :class="mtype == 'YC' && 'toptabToponlyliHover'" class="toptabToponlyli" @click="getType('YC')">йҒҘжөӢ</li>
      <li :class="mtype == 'BX' && 'toptabToponlyliHover'" class="toptabToponlyli" @click="getType('BX')">жҠҘжұӣ</li>
    </ul> -->
        <span style="margin-left: 20px">з«ҷзӮ№йҖүжӢ©пјҡ</span>
        <el-cascader style="max-width: 120px;" v-model="value" :options="Liststnm" @change="handleChange" />
        <span style="margin-left: 20px">ејҖе§Ӣж—¶й—ҙпјҡ</span>
        <!-- <el-config-provider class="stime-ccustom" :locale="locale">
      <el-date-picker class="datatime" v-model="stime" type="datetime" placeholder="йҖүжӢ©ж—Ҙжңҹ" format="YYYY-MM-DD HH:mm"
        time-format="HH:mm" @change="StimeeChange">
      </el-date-picker>
       
    </el-config-provider> -->
        <input id="STIME" class="mini-datepicker" style="width:135px;" format="yyyy-MM-dd HH:mm" timeFormat="HH:mm"
            showTime="true" showOkButton="true" showClearButton="false" />
        <span style="margin-left: 20px">з»“жқҹж—¶й—ҙпјҡ</span>
        <input id="ETIME" class="mini-datepicker" style="width:135px;" format="yyyy-MM-dd HH:mm" timeFormat="HH:mm"
            showTime="true" showOkButton="true" showClearButton="false" />
        <el-radio-group style="margin-left: 20px">
            <el-radio @click="TypeeChange('Minute')" v-model="pathname" label="Minute">еҲҶй’ҹ</el-radio>
            <el-radio @click="TypeeChange('HOUR')" v-model="pathname" label="HOUR">е°Ҹж—¶</el-radio>
            <el-radio @click="TypeeChange('DAY')" v-model="pathname" label="DAY">8ж—¶</el-radio>
        </el-radio-group>
        <ul class="toptabTop" style="margin-right: 20px">
            <li :class="TMtype == 'week' && 'toptabToponlyliHover'" class="toptabToponlyli" @click="geTMtType('week')"
                style="border-right: 1px solid var(--swDivSelectcolor);">дёҖе‘Ё</li>
            <li :class="TMtype == 'month' && 'toptabToponlyliHover'" class="toptabToponlyli" @click="geTMtType('month')"
                style="border-right: 1px solid var(--swDivSelectcolor);">дёҖжңҲ
            </li>
            <li :class="TMtype == 'year' && 'toptabToponlyliHover'" class="toptabToponlyli" @click="geTMtType('year')">дёҖе№ҙ
            </li>
        </ul>
        <el-button type="primary" @click="BtnSearch()">жҹҘиҜў</el-button>
        <el-button type="warning" @click="DuoSearch()">еӨҡз«ҷеҜ№жҜ”</el-button>
        <el-button type="success" @click="YBSearch()" id="yubao">йў„жҠҘ</el-button>
        <div style="position: absolute;top: 100px;right: 90px;cursor: pointer;" v-if="WarningInfoID" @click="WarningInfo()"
            title="еә”жҖҘе“Қеә”жқЎд»¶">
            <img src="/images/cloud/yjtb.png" alt="" />
        </div>
        <span
            style="position: absolute;right: 20px;width: 70px;height: 30px;margin: 5px 0px;background: rgb(238 238 238 / 60%);border-radius: 5px;">
            <span class="switch" style="border-radius: 5px 0px 0px 5px" @click="OnBoot('fit1')"
                :class="tabName == 'fit1' && 'handleon'">
                <img :src="img1" />
            </span>
            <span class="switch" style="border-radius: 0px 5px 5px 0px; margin-left: 35px" @click="OnBoot('fit2')"
                :class="tabName == 'fit2' && 'handleon'">
                <img :src="img2" />
            </span>
        </span>
    </div>
    <div style="height:450px; width: 100%; margin-top: 10px">
        <div class="content-echarts">
            <Echarts :width="'100%'" :height="'100%'" :option="lineOption" :key="datekey" id="SQLine" />
        </div>
        <div class="content-table">
            <Table :headers="tableHeaders" :rows="tableData" :key="datekey" class="tableYQ" :border="0" :cellspacing="0"
                :cellpadding="0" />
        </div>
    </div>
    <div id="divEchartsData" class="echartsmaxmindata">
    </div>
    <MyDialog :showDialog="showDialog" @close="showDialog = false" :title="title" :typeValue="typeValue"
        style="width: 1400px; height: 800px">
        <SQLineDuo />
    </MyDialog>

    <MyDialog :showDialog="showDialogYB" @close="showDialogYB = false" :title="titleYB" :typeValue="typeValueYB"
        style="width: 1400px; height: 800px">
        <SQLineYB />
    </MyDialog>
</template>
<script setup>
import Table from "@/components/Table/Table.vue";
import MyDialog from "@/components/ComDialog.vue";
import SQLineDuo from "@/components/danzhan/sq/SQLineDuo.vue";
import SQLineYB from "@/components/danzhan/sq/SQLineYB.vue";
import api from "@/api/zonglan/index.js";
import Echarts from "@/components/MyEcharts/echartsLine.vue";
import ChartJs from "@/api/MyEcharts/ChartJs.js";
import { SetNull, sortObjectArray } from "@/api/ComUnit.js";
import { Postcard } from "@element-plus/icons-vue";
// ElConfigProviderпјҡж—¶й—ҙйҖүжӢ©жЎҶжұүеҢ–
import { ElDatePicker, ElRadio, ElButton, ElConfigProvider, ElCascader, ElMessage } from "element-plus";
import dayjs from "dayjs";
import $ from "jquery";

import { ref, onMounted, provide, inject } from "vue";
// иҺ·еҸ–еҪ“еүҚдё»йўҳ
const _theme = localStorage.getItem("curTheme");
const datekey = ref(null);
const lineOption = ref({});
const SQdata = ref({});
const stime = ref("");
const etime = ref("");
const stcd = ref("");
const stnm = ref("");
const pathname = ref("Minute");
const mtype = ref("");
const TMtype = ref("");
const tabName = ref("fit1");
const img1 = ref("/images/line-chart.png");
const img2 = ref("/images/line-table4.png");
const Liststnm = ref([]);
const value = ref([])
// еҲӨж–ӯеј№зӘ—жҳҜеҗҰжҳҫзӨә,й»ҳи®Өйҡҗи—Ҹ
const showDialog = ref(false);
const title = ref("ж°ҙдҪҚеӨҡз«ҷеҜ№жҜ”");
const typeValue = ref("");
const showDialogYB = ref(false);
const titleYB = ref("еҚ•з«ҷж°ҙдҪҚйў„жҠҘ");
const typeValueYB = ref(false);
const WarningInfoID = ref(false);
const tableHeaders = ref([
    { name: "num", label: "еәҸеҸ·" },
    { name: "tm", label: "ж—¶й—ҙ" },
    { name: "upz", label: "дёҠжёёж°ҙдҪҚ(m)" },
    { name: "dwz", label: "дёӢжёёж°ҙдҪҚ(m)" },
    { name: "wrz", label: "иӯҰжҲ’ж°ҙдҪҚ(m)" },
    { name: "grz", label: "дҝқиҜҒж°ҙдҪҚ(m)" },
]);
const tableData = ref();
// иҺ·еҸ–йӣЁеһӢзҡ„зұ»еһӢпјҡ1:(е°Ҹ~дёӯйӣЁ);2:(дёӯйӣЁ);3:(жҡҙйӣЁ);4:(еӨ§жҡҙйӣЁ);5:(зү№еӨ§жҡҙйӣЁ);
const props = defineProps({
    stcd: {
        type: String,
        default: "",
    },
    mtype: {
        type: String,
        default: "",
    },
    stime: {
        type: String,
        default: "",
    },
    etime: {
        type: String,
        default: "",
    },
});
function loadZhan() {
    value.value = [stcd.value];
    api.QuSel({ "pid": "2026031114184492913-2" }).then((res) => {
        // console.error("res", res.data)
        var strJson = [];
        if (res.data.length > 0) {
            for (var i = 0; i < res.data.length; i++) {
                var strTemp = {
                    value: res.data[i].stcd,
                    label: res.data[i].stnm,
                    children: []
                }
                strJson.push(strTemp)
            }
        }
        Liststnm.value = strJson;
    });

}

function Weacontent() {
    window.loadingShow();
    var strParam = {};
    strParam["stcd"] = stcd.value;
    strParam["pathname"] = pathname.value;
    strParam["stime"] = dayjs(mini.get("STIME").getFormValue()).format("YYYY-MM-DD HH:mm") + ":00";
    strParam["etime"] = dayjs(mini.get("ETIME").getFormValue()).format("YYYY-MM-DD HH:mm") + ":00";
    strParam["datasource"] = mtype.value;
    api
      .stPptnWaterLine(strParam)
      .then((res) => {        
        const strJson = res.data;
        // var jsondata = strJson.sort(function (a, b) {
        //   return dayjs(a.tm).format("YYYY-MM-DD HH:mm:ss") - dayjs(b.tm).format("YYYY-MM-DD HH:mm:ss"); //ж—¶й—ҙжӯЈеәҸ
        // });
        SQdata.value = strJson;
        SQload();
        window.loadingHide();
    })
    .catch((err) => { });
}
function SQload() {
    const strJson = SQdata.value;
    const strNote = [];
    strNote.push({ name: "ж—¶й—ҙ", codename: "tm", tableV: "0", isShow: true });
    const tempJson = strJson.filter(function (res) {
        let _flag = false;
        if (SetNull(res["upz"]) != "") {
            if (Number(res["upz"]) <= 0) {
                res["upz"] = null;
            }
        }
        else {
            res["upz"] = null;
        }
        if (SetNull(res["dwz"]) != "") {
            if (Number(res["dwz"]) <= 0) {
                res["dwz"] = null;
            }
        }
        if (SetNull(res["dwz"]) != "") {
            if (Number(res["dwz"]) > 0) {
                _flag = true;
            }
        }
        return _flag;
    })
    if (tempJson.length > 0) {
        tableHeaders.value = [
            { name: "num", label: "еәҸеҸ·" },
            { name: "tm", label: "ж—¶й—ҙ" },
            { name: "upz", label: "дёҠжёёж°ҙдҪҚ(m)" },
            { name: "dwz", label: "дёӢжёёж°ҙдҪҚ(m)" },
            { name: "wrz", label: "иӯҰжҲ’ж°ҙдҪҚ(m)" },
            { name: "grz", label: "дҝқиҜҒж°ҙдҪҚ(m)" },
        ]
        strNote.push({ name: "дёҠжёёж°ҙдҪҚ", codename: "upz", tableV: "0", isShow: true });
        strNote.push({ name: "дёӢжёёж°ҙдҪҚ", codename: "dwz", tableV: "0", isShow: true });
    }
    else {
        tableHeaders.value = [
            { name: "num", label: "еәҸеҸ·" },
            { name: "tm", label: "ж—¶й—ҙ" },
            { name: "upz", label: "е®һж—¶(m)" },
            { name: "wrz", label: "иӯҰжҲ’ж°ҙдҪҚ(m)" },
            { name: "grz", label: "дҝқиҜҒж°ҙдҪҚ(m)" },
        ]
        strNote.push({ name: "е®һж—¶", codename: "upz", tableV: "0", isShow: true });
    }
    var oneJson = strJson.filter(function (evt) {
        return SetNull(evt["accdw"]) != "";
    })
    if (oneJson.length > 0) {
        strNote.push({ name: "еј•ж°ҙи°ғеәҰзәҝ", codename: "accpw", tableV: "0", isShow: true });
        strNote.push({ name: "жҺ’ж°ҙи°ғеәҰзәҝ", codename: "accdw", tableV: "0", isShow: true });
        tableHeaders.value.push({ name: "accpw", label: "еј•ж°ҙи°ғеәҰзәҝ(m)" })
        tableHeaders.value.push({ name: "accdw", label: "жҺ’ж°ҙи°ғеәҰзәҝ(m)" })
    }
    strNote.push({ name: "иӯҰжҲ’", codename: "wrz", tableV: "0", isShow: false });
    strNote.push({ name: "дҝқиҜҒ", codename: "grz", tableV: "0", isShow: false });
    var LineColor = [
        "#4EFF4E",
        "#FF0000",
        "green",
        "#1CB8B2",
        "#01DDFF",
        "#F9C823",
        "#0264FD",
        "#FE7923",
        "#8E30FF",
    ];
    const _Option = ChartJs.chartSW(
        "",
        sortObjectArray(strJson, ["tm"], "asc"),
        strNote,
        LineColor,
        "ж°ҙдҪҚ",
        "Mouth",
        _theme,
        80,
        20
    );

    lineOption.value = _Option;
    datekey.value = Date.now();

    var result = [];
    var maxZ = -1, maxTM = null;
    var minZ = 999, minTM = null;
    for (var num = 0; num < strJson.length; num++) {
        var item = strJson[num];
        var wrz = item.wrz != undefined ? Number(item.wrz).toFixed(2) : "вҖ”";
        var grz = item.grz != undefined ? Number(item.grz).toFixed(2) : "вҖ”";
        var upz = item.upz != undefined ? Number(item.upz).toFixed(2) : "вҖ”";
        var dwz = item.dwz != undefined ? Number(item.dwz).toFixed(2) : "вҖ”";
        var tm = dayjs(new Date(item.tm)).format("YYYY-MM-DD HH:mm");

        var wrzCha = "вҖ”";
        var colorCss = "";
        if (wrz != "вҖ”") {
            if (upz != "вҖ”") {
                wrzCha = Number(Number(upz) - Number(wrz)).toFixed(2);
            } else {
                if (dwz != "вҖ”") {
                    wrzCha = Number(Number(dwz) - Number(wrz)).toFixed(2);
                }
            }
            if (Number(wrzCha) > 0) {
                colorCss = "#F9C33D";
            }
        }

        if (grz != "вҖ”") {
            if (upz != "вҖ”") {
                if (Number(Number(upz) - Number(grz)).toFixed(2) > 0) {
                    colorCss = "#F70019";
                }
            } else {
                if (dwz != "вҖ”") {
                    if (Number(Number(dwz) - Number(grz)).toFixed(2) > 0) {
                        colorCss = "#F70019";
                    }
                }
            }
        }

        if (SetNull(upz) != "") {
            if (SetNull(upz) != "вҖ”") {
                if (upz > maxZ) {
                    maxZ = upz;
                    maxTM = tm;
                }
                if (upz < minZ) {
                    minZ = upz;
                    minTM = tm;
                }
            }
            else {
                var tempUpz = dwz;
                if (SetNull(tempUpz) != "вҖ”") {
                    if (tempUpz > maxZ) {
                        maxZ = tempUpz;
                        maxTM = tm;
                    }
                    if (tempUpz < minZ) {
                        minZ = tempUpz;
                        minTM = tm;
                    }
                }
            }
        }

        result.push({ tm: tm, upz: upz, dwz: dwz, wrz: wrz, grz: grz, colorCss: colorCss });
    }
    var strMsg = `жңҖдҪҺж°ҙдҪҚпјҡ<span style='color:#0cdc0c;font-size: 18px;'>${minZ}</span>mпјҲ${minTM}пјү
  &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 
жңҖй«ҳж°ҙдҪҚпјҡ<span style='color:#0cdc0c;font-size: 18px;'>${maxZ}</span>mпјҲ${maxTM}пјү
    `;
    if(minZ==999){
        strMsg = `жңҖдҪҺж°ҙдҪҚпјҡ<span style='color:#0cdc0c;font-size: 18px;'>-</span>
  &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 
жңҖй«ҳж°ҙдҪҚпјҡ<span style='color:#0cdc0c;font-size: 18px;'>-</span>
    `;
    }
    $("#divEchartsData").html(strMsg);
    // tableData.value = sortObjectArray(result, ["tm"], "desc");
    let _index = 0;
    tableData.value = sortObjectArray(result, ["tm"], "desc").filter(res => {
        _index = _index + 1;
        res.num = _index;
        return res;
    });
}
function getType(obj) {
    mtype.value = obj;
    Weacontent();
}
function geTMtType(obj) {
    TMtype.value = obj;
    var now = new Date();
    etime.value = dayjs(now).format("YYYY-MM-DD HH:mm:ss");
    if (obj == "week") {
        stime.value = dayjs(etime.value).add(-6, "day").format("YYYY-MM-DD HH:mm:ss");
    } else if (obj == "month") {
        stime.value = dayjs(etime.value).add(-1, "month").format("YYYY-MM-DD HH:mm:ss");
    } else if (obj == "year") {
        stime.value = dayjs(etime.value).add(-1, "year").format("YYYY-MM-DD HH:mm:ss");
    }
    mini.get("STIME").setValue(dayjs(stime.value).format("YYYY-MM-DD HH:00"));
    mini.get("ETIME").setValue(dayjs(etime.value).format("YYYY-MM-DD HH:00"));
    Weacontent();
}
function WarningInfo() {
    var strMsgLast = "";
    if (stcd.value == "63201999") {
        strMsgLast = "<div style='font-size: 16px;line-height: 25px;color:#000;'>йҳІжұӣе“Қеә”жқЎд»¶пјҡеӨӘж№–ж°ҙдҪҚв…Јзә§пјҡ4.00mпјҢв…ўзә§пјҡ4.20mпјҢв…Ўзә§пјҡ4.66mпјҢв… зә§пјҡ4.97m</div>";
        strMsgLast += "<div style='font-size: 16px;line-height: 25px;color:#000;'>жҠ—ж—ұе“Қеә”жқЎд»¶пјҡеӨӘж№–ж°ҙдҪҚв…Јзә§пјҡ2.95mпјҢв…ўзә§пјҡ2.90mпјҢв…Ўзә§пјҡ2.85mпјҢв… зә§пјҡ2.80m</div>";
    } else if (stcd.value == "63203000") {
        strMsgLast = "<div style='font-size: 16px;line-height: 25px;color:#000;'>йҳІжұӣе“Қеә”жқЎд»¶пјҡжһ«жЎҘв…Јзә§пјҡ4.00mпјҢв…ўзә§пјҡ4.20mпјҢв…Ўзә§пјҡ4.60mпјҢв… зә§пјҡ4.95m</div>";
    } else if (stcd.value == "63205350") {
        strMsgLast = "<div style='font-size: 16px;line-height: 25px;color:#000;'>йҳІжұӣе“Қеә”жқЎд»¶пјҡе№іжңӣв…Јзә§пјҡ3.90mпјҢв…ўзә§пјҡ4.00mпјҢв…Ўзә§пјҡ4.20mпјҢв… зә§пјҡ4.45m</div>";
    } else if (stcd.value == "63204650") {
        strMsgLast = "<div style='font-size: 16px;line-height: 25px;color:#000;'>йҳІжұӣе“Қеә”жқЎд»¶пјҡж№ҳеҹҺв…Јзә§пјҡ3.80mпјҢв…ўзә§пјҡ3.90mпјҢв…Ўзә§пјҡ4.00mпјҢв… зә§пјҡ4.31m</div>";
    } else if (stcd.value == "63403500") {
        strMsgLast = "<div style='font-size: 16px;line-height: 25px;color:#000;'>йҳІжұӣе“Қеә”жқЎд»¶пјҡйҷҲеў“в…Јзә§пјҡ3.70mпјҢв…ўзә§пјҡ3.80mпјҢв…Ўзә§пјҡ3.90mпјҢв… зә§пјҡ4.33m</div>";
    }
    ElMessage({
        message: strMsgLast,
        type: 'warning',
        center: true,
        duration: 5000,
        showClose: true,
        dangerouslyUseHTMLString: true,
        onClose: () => {
            console.log('ж¶ҲжҒҜе·Іе…ій—ӯ')
        },
        offset: 50,
        style: {
            // и®ҫзҪ®еӯ—дҪ“еӨ§е°ҸпјҢе№¶дҪҝз”Ё !important е…ій”®еӯ—
            fontSize: '18px',
            lineHeight: '30px',
        },
        customClass: 'custom-message',
        round: true
    })
}
function handleChange(value) {
    // console.error(value)
    stcd.value = value[0];
    if (STCD.indexOf(stcd.value) > -1) {
        $("#yubao").show();
    } else {
        $("#yubao").hide();
    }
    Weacontent();
}
function TypeeChange(e) {
    pathname.value = e;
    Weacontent();
}
function BtnSearch() {
    Weacontent();
}
function DuoSearch() {
    showDialog.value = true;
}
function YBSearch() {
    showDialogYB.value = true;
}
function OnBoot(e) {
    tabName.value = e;
    SQload();
    if (e == "fit1") {
        $(".content-echarts").css({ display: "block" });
        $(".content-table").css({ display: "none" });

        img1.value = "/images/line-chart.png";
        img2.value = "/images/line-table4.png";
    } else if (e == "fit2") {
        $(".content-echarts").css({ display: "none" });
        $(".content-table").css({ display: "block" });

        img1.value = "/images/line-chart1.png";
        img2.value = "/images/line-table3.png";
    }
}
var STCD = "63203050,63203000,63205150,63403500,63204650";
onMounted(() => {
    mini.parse();
    if (props.stcd != "") {
        stcd.value = props.stcd;
    } else {
        stcd.value = inject("stcd").value;
    }
    if ("63201999,63203000,63205350,63204650,63403500".lastIndexOf(stcd.value) > -1) {
        WarningInfoID.value = true;
    }
    if (props.stime != "") {
        stime.value = props.stime
    } else {
        stime.value = inject("stime").value;
    }
    if (props.etime != "") {
        etime.value = props.etime
    } else {
        etime.value = inject("etime").value;
    }
    // if (props.mtype != "") {
    //   mtype.value = props.mtype;
    // } else {
    //   mtype.value = inject("mtype").value;
    // }
    // зЎ®дҝқ MiniUI иө„жәҗеҠ иҪҪе®ҢжҲҗеҗҺеҶҚж“ҚдҪң
    stime.value = dayjs(etime.value).add(-24, "hour").format("YYYY-MM-DD HH:00");
    // е°қиҜ•иҺ·еҸ–з»„д»¶е®һдҫӢ
    mini.get("STIME").setValue(dayjs(stime.value).format("YYYY-MM-DD HH:00"));
    mini.get("ETIME").setValue(dayjs(etime.value).format("YYYY-MM-DD HH:00"));
    loadZhan();
    Weacontent();
    if (STCD.indexOf(stcd.value) > -1) {
        $("#yubao").show();
    } else {
        $("#yubao").hide();
    }
});
provide("typestcd", stcd);
</script>
