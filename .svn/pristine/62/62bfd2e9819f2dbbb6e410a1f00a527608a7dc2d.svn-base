const typenameRadio = ref(2);
function handleChange(val) {
  $(".LabelPlotBeautifulDRP").remove();
  if (val == 1) { 
    pid.value = '201901101419326076-1-1';//所有站
  } else if (val == 5) {
    pid.value = '201901101419326076-3';//35个代表站
  }
  pid.value
  Weacontent();
}
//自动刷新
var interVal;
window.curDataRefresh = function () {
  if (interVal != null) {
    clearInterval(interVal);
  }
  if (localStorage.getItem("curDataRefresh") == "true") {
    interVal = setInterval(function () {
      refreshData();
    }, 180000);//180000
  }
}
//刷新的方法
function refreshData() {
  var _curDataRefresh = localStorage.getItem("curDataRefresh");
  if (_curDataRefresh == true || _curDataRefresh == 'true') {
    Weacontent();
  } else {
    if (interVal != null && interVal != undefined) {
      clearInterval(interVal);
    }
  }
}
onUnmounted(() => {
  $(".LabelPlotBeautifulDRP").remove();
  if (interVal != null) {
    clearInterval(interVal);
  }
})
function Weacontent() {
  var strParam = {};
  strParam["pid"] = pid.value;
  strParam["stime"] = stime.value;
  strParam["etime"] = etime.value;
  strParam["pathname"] = "SUM";
  var TYPEname = "(所有)";
  //   strParam["datasource"] = "BX";

  tmCenter.value = dayjs("2025-07-30 08:00:00").format("M月D日 H时") + "至" + dayjs("2025-07-31 08:00:00").format("M月D日 H时");
  apizonglan.stPptnRain(strParam).then((res) => {
    strJsonData.value = res.data;
    if (datekeyAllname.value == true) {
      datekeyAll.value = dayjs(dayjs(Date.now()).format("YYYY-MM-DD HH:mm:ss")).add(6, "hour").format("YYYY-MM-DD HH:mm:ss");
    }
    YLload();
  });
}
var PicUrl = "/xishanyuntu/weather/";
function SpanItem(obj) {
  if (obj == "riverMarker") {
    PointMark.addYLMark(viewer, YLDATA.value, stime.value, etime.value, riverMarker.value);
  } 
  else if (obj == "RainDZMMarker") {
    MapRainfall();
  }
}
var RainfallStr =[];
function YLload() {
    RainfallStr=[];
    var count0 = 0,
    count0_10 = 0,
    count10_25 = 0,
    count25_50 = 0,
    count50_100 = 0,
    count100_250 = 0,
    count250 = 0;
  var strJson = strJsonData.value;

  resultPptnRain = reactive([]);
  if (strJson.length > 0) {
    for (var i = 0; i < strJson.length; i++) {
      var item = strJson[i];
      if (item.drp == undefined) {
        item.drp = 0.0;
      }
      var f = Number(item.drp);
      if (f >= 250.0) {
        count250++;
        if (rainfall250.value) {
          resultPptnRain.push(item);
        }
      } else if (f >= 100.0) {
        count100_250++;
        if (rainfall100_250.value) {
          resultPptnRain.push(item);
        }
      } else if (f >= 50.0) {
        count50_100++;
        if (rainfall50_100.value) {
          resultPptnRain.push(item);
        }
      } else if (f >= 25.0) {
        count25_50++;
        if (rainfall25_50.value) {
          resultPptnRain.push(item);
        }
      } else if (f >= 10.0) {
        count10_25++;
        if (rainfall10_25.value) {
          resultPptnRain.push(item);
        }
      } else if (f > 0) {
        count0_10++;
        if (rainfall0_10.value) {
          resultPptnRain.push(item);
        }
      } else {
        count0++;
        if (rainfall0.value) {
          resultPptnRain.push(item);
        }
      }

      if(f>0){
          // if (RainfallStr == "") {
          //    RainfallStr += item.lgtd84 + "," + item.lttd84 + "," + f;
          // } else {
          //    RainfallStr += "|" + item.lgtd84 + "," + item.lttd84 + "," + f;
          // }
          RainfallStr.push({lon:item.lgtd84, lat: item.lttd84, value: f});
      }
    }
  }
  YLDATA.value = resultPptnRain;
  $("#value0").html("" + count0 + "");
  $("#value0_10").html("" + count0_10 + "");
  $("#value10_25").html("" + count10_25 + "");
  $("#value25_50").html("" + count25_50 + "");
  $("#value50_100").html("" + count50_100 + "");
  $("#value100_250").html("" + count100_250 + "");
  $("#value250").html("" + count250 + "");
  PointMark.addYLMark(viewer, resultPptnRain, stime.value, etime.value, riverMarker.value);
  // SpanItem("RainDZMMarker");
}
