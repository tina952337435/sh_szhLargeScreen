    onMounted(() => {
        bindData();
    });
    function bindData(){
        var dataTemp = zhanDianData.filter(function (res) {
            return res.STCD == "81450";//入流
        });
        var totalRSL = SumJson(dataTemp, 'DATA');
        totalRSL = totalRSL * 0.36;//流量转水量，万方

        dataTemp = zhanDianData.filter(function (res) {
            return res.STCD == "81449";//出流
        });
        var totalCSL = SumJson(dataTemp, 'DATA');
        totalCSL = totalCSL * 0.36;//流量转水量，万方

        dataTemp = zhanDianData.filter(function (res) {
            return res.STCD == "81346";//嘉宝北片降雨产流
        });
        // console.error(dataTemp);
        var totalJYCL = SumJson(dataTemp, 'DATA');
        totalJYCL = Math.abs(totalJYCL) * 0.36;//流量转水量，万方

        var data=[];
        var jsl=Number(totalRSL)-Number(totalCSL);
        data.push({stnm:"累计",accpw:totalRSL.toFixed(2),accdw: totalCSL.toFixed(2),jsl:jsl.toFixed(2)});

        var jbbpNameArr = ["沿长江", "沿浦东片", "沿浏河", "沿太北太南片"];
        for (var num = 0; num < jbbpNameArr.length; num++) {
            var totalCSL = 0;
            var totalRSL = 0;
            var jsl=0;
            var name = jbbpNameArr[num];
            var zhanDianTemp = zhanDian.filter(function (res) {
                return res.NAME.indexOf(name) > -1 && res.TYPE == "24";
            });
            var stcd = zhanDianTemp[0].STCD;
            var zhanDianDataTemp = zhanDianData.filter(function (res) {
                return res.STCD == stcd;
            });
            totalRSL = SumJson(zhanDianDataTemp, 'DATA');
            totalRSL = totalRSL * 0.36;//流量转水量，万方

            zhanDianTemp = zhanDian.filter(function (res) {
                 return res.NAME.indexOf(name) > -1 && res.TYPE == "25";
            });
            stcd = zhanDianTemp[0].STCD;
            zhanDianDataTemp = zhanDianData.filter(function (res) {
                return res.STCD == stcd;
            });
            totalCSL = SumJson(zhanDianDataTemp, 'DATA');
            totalCSL = totalCSL * 0.36;//流量转水量，万方    

            jsl=Number(totalRSL)-Number(totalCSL);

            var center=[];
            if(name=="沿长江"){
                center = [121.425514, 31.458566];
            }
            else if(name=="沿浦东片"){
                center = [121.524556,31.22897];
            }
            else if(name=="沿浏河"){
                center = [121.201153, 31.471097];
            }
            else if(name=="沿太北太南片"){
                 center = [121.103014, 30.902706];
            }
            data.push({ 
                stnm: name, 
                accpw: totalRSL.toFixed(2), 
                accdw: totalCSL.toFixed(2), 
                jsl: jsl.toFixed(2),
                lgtd:center[0],
                lttd:center[1]
            });  
        }
        data.push({ stnm: "降雨产流", jsl: totalJYCL.toFixed(2)});
        tableData.value=data;

        emit("parentMethods", tableData.value);
    }
    const emit = defineEmits(['opencurrentComponentTanchu', 'parentMethods']);
</script>
