.navbar {
    height: 60px;
    background: #017de4 !important;
    position: relative;
    border-bottom: 0;
    margin-bottom: 0;
    padding-top: 12px;
}

.navbar-right {
    position: absolute;
    right: 0;
    top: 0;
}

.nav {
    padding-left: 0;
    margin: 0;
    list-style: none;
}

.menu {
    background: none;
    float: left;
    margin-right: 50px;
    height: 52px;
    z-index: 999;
}

.menu li {
    list-style-type: none;
    text-align: center;
    padding: 0px 10px;
    float: left;
    margin-left: 5px;
    height: 38px;
}