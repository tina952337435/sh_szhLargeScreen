/*详情导出*/
.daochu a {
    width: 60px;
    margin-left: 20px;
    background: #3291f9;
    color: white;
    line-height: 25px;
    text-align: center;
    border-radius: 5px;
    height: 25px;
    display: block;
    float: left;
    cursor: pointer;
}

/*地图右侧表格边框
.mini-grid-cell{border-bottom:none !important;}
.mini-grid-cell:last-of-type{border-right:none !important;}
.mini-grid-row:last-of-type .mini-grid-cell{border-bottom:#ddd 1px solid !important;}*/

::-webkit-scrollbar {
    width: 4px;
    height: 10px;
}

::-webkit-scrollbar-thumb {
    border-radius: 5px;
    -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);
    background: #3291f9;
}

::-webkit-scrollbar-track {
    -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);
    border-radius: 0;
    background: rgba(0, 0, 0, 0.1);
}


.mini-panel-border .mini-grid-border {
    font-size: 13px;
    font-family: Tahoma, Verdana, 宋体 !important;
}

.NONEp {
    width: 8px;
    height: 24px;
    float: left;
    background: #2a8eff;
    margin-top: 3px;
    margin-right: -4px;
}

.box {
    margin-top: 2px;
}



/*滚动条样式*/
.mini-grid-rows-view::-webkit-scrollbar {
    /*滚动条整体样式*/
    width: 4px !important;
    /*高宽分别对应横竖滚动条的尺寸*/
    height: 8px !important;
}

.mini-grid-rows-view::-webkit-scrollbar-thumb {
    /*滚动条里面小方块*/
    border-radius: 5px !important;
    -webkit-box-shadow: inset 0 0 5px #3291f9 !important;
    height: 80px;
    background: #3291f9 !important;
}

.mini-grid-rows-view::-webkit-scrollbar-track {
    /*滚动条里面轨道*/
    -webkit-box-shadow: inset 0 0 8px #efefef !important;
    border-radius: 0 !important;
    background: #efefef !important;
}

.mini-grid-columns-view {
    padding-right: 0px !important;
}

