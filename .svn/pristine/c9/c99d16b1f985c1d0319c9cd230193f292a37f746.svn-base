body {
    font-family: "arial", "Hiragino Sans GB", "Helvetica Neue", Helvetica, tahoma, arial, "WenQuanYi Micro Hei", Verdana, sans-serif, "\5B8B\4F53";
    background: #fff;
}

.container {
    min-width: 1366px;
}

.mini-tabs-bodys {
    _width: 100% !important;
    padding: 0px !important;
}

.mini-state-default,
.mini-button,
.mini-tabs-leftButton,
.mini-tabs-rightButton,
.mini-tabs-tabmenu,
.mini-tab,
.mini-textboxlist .mini-textboxlist-item,
.mini-htmlfile .mini-buttonedit-button {
    /*background: #3291f9;
    color: white;
    cursor: pointer;  
    font-size: 14px;
    border-radius: 2px;*/
}

body .mini-button-checked {
    background: #0039ff;
}

/*按钮*/
.mini-toolbar {
    position: relative;
    border: 0px;
    /* border-bottom: solid 1px #c0c6ce; */
    /*border: solid 1px #c0c6ce;*/
    /*background: #F5FAFE;*/
    background: white;
    margin-bottom: 2px;
    /*margin-top: 5px;*/
    padding: 5px;
    vertical-align: middle;
}

.mini-button {
    background: #3291F9;
    color: #ffffff;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    border-radius: 4px;
}

.mini-button .mini-button-icon-text {
    padding: 3px 15px;
    background: #3291f9;
    color: white;
    border-radius: 4px !important;
}

.mini-button-text {
    position: relative;
    line-height: 16px;
    display: inline-block;
    vertical-align: baseline;
    padding: 3px;
    font-size: 12px;
}

.mini-edit-text>.mini-button-text {
    font-size: 15px;
    padding: 0px 29px;
    line-height: 30px;
}

body a:hover.mini-button {
    background: #3291F9;
    color: #ffffff;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    border-radius: 4px;
}

/*文本框*/
.mini-textbox-input {
    cursor: text;
    color: #333;
    background: none;
    width: 100%;
    height: 22px;
    line-height: 20px;
    font-family: Verdana;
    font-size: 9pt;
    border: 0;
    padding: 0;
    margin: 0;
    outline: none;
}

.mini-textbox-border {
    background: white;
    border-color: #ddd;
    border-radius: 4px;
    border: solid 1px #a5acb5;
    width: auto;
    display: block;
    position: relative;
    overflow: hidden;
    padding-left: 4px;
    padding-right: 4px;
}

/*表格*/
#grid1 {
    /*width: -webkit-calc(100% - 4px) !important;
    width: -moz-calc(100% - 4px) !important;
    width: calc(100% - 4px) !important;*/
    width: 100%;
}

/* 列表选中*/
html body .mini-grid-row-selected {
    background: #FFF1DF !important;
}

/*鼠标移上去*/
html body .mini-grid-row-hover {
    background: #FFF1DF !important;
}

