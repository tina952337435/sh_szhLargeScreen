/*******表格****/
table.table {
    clear: both;
    margin-bottom: 6px !important;
    max-width: none !important;
    border-spacing: 0;
    border-collapse: collapse;
    background-color: transparent;
}

.table-bordered tr th,
.table-bordered tr td,
.table-bordered tbody tr td {
    border: 1px solid #A5ACB5;
}

.table>thead>tr>th,
.table>tbody>tr>th,
.table>tfoot>tr>th,
.table>thead>tr>td,
.table>tbody>tr>td,
.table>tfoot>tr>td {
    padding: 3px;
    line-height: 1.42857143;
}

.table tr th,
.table tr td {
    vertical-align: middle !important;
}

.none {
    display: none !important;
}

.mini-tools-max {
    color: #ffffff !important;
}

.mini-tools-close {
    color: #ffffff !important;
}

.layui-text {
    line-height: 22px;
    font-size: 14px;
    color: #666;
}

.layui-elem-quote {
    margin-bottom: 10px;
    padding: 15px;
    line-height: 22px;
    border-left: 5px solid #3291F9;
    border-radius: 0 2px 2px 0;
    background-color: #f2f2f2;
}


/*选择线性和表格*/
.bootstrap-switch {
    display: inline-block;
    direction: ltr;
    cursor: pointer;
    border-radius: 4px;
    border: 1px solid;
    border-color: #cccccc;
    position: relative;
    text-align: left;
    overflow: hidden;
    line-height: 8px;
    z-index: 0;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
    vertical-align: middle;
    -webkit-transition: border-color ease-in-out .15s, box-shadow ease-in-out .15s;
    transition: border-color ease-in-out .15s, box-shadow ease-in-out .15s;
}

.bootstrap-switch-handle-on,
.bootstrap-switch-handle-off {
    -webkit-box-sizing: border-box;
    -moz-box-sizing: border-box;
    box-sizing: border-box;
    cursor: pointer;
    display: inline-block !important;
    height: 100%;
    padding: 6px 12px;
    font-size: 14px;
    line-height: 20px;
}

.bootstrap-switch-handle-off {
    color: #000;
    background: #eeeeee;
}

.bootstrap-switch-handle-on {
    color: #fff;
    background: #3291f9;
    border-bottom-left-radius: 0;
    border-top-left-radius: 0;
    border-bottom-right-radius: 3px;
    border-top-right-radius: 3px;
}

.CssTitle {
    font-size: 16px;
    font-weight: 600;
    color: black;
    height: 60px;
}

.open {
    box-shadow: 0 0 6px rgba(0, 0, 0, .1), 0 4px 6px rgba(0, 0, 0, .1);
    transform: translate3d(0, -3px, 0);
    background: -webkit-linear-gradient(top, #52C8F7 0.00%, #38C0F6 32.86%, #0AA0DB 68.93%, #098ABD 100.00%);
    background: linear-gradient(top, #F58246 0.00%, #ED7F44 32.86%, #CC7244 68.93%, #BE6E48 100.00%);
    /*box-shadow: 0 2px 1px 0 #4595f7, 0 4px 1px -1px #2578e8, 0 6px 1px -2px #1e85f7, 0 8px 1px -3px #207ce9, 0 10px 1px -4px #1c71dc, 0 12px 1px -5px #0e68dc, 0 14px 1px -6px #3f7dd0, 0 16px 1px -7px #2364bb, 0 18px 1px -8px #255ea7, 0 20px 1px -9px #023a7d, 0 6px 1px rgba(0, 0, 0, 0.1), 0 0 5px rgba(0, 0, 0, 0.1), 0 10px 20px rgba(0, 0, 0, 0.75), 0 20px 4px -6px rgba(0, 0, 0, 0.9), 0 45px 5px -5px rgba(0, 0, 0, 0.05), 0 35px 10px -5px rgba(0, 0, 0, 0.1), 0 25px 55px 5px rgba(0, 0, 0, 0.15);*/
    box-shadow: 0 2px 1px 0 #4595f7, 0 4px 1px -1px #2578e8, 0 6px 1px -2px #1e85f7, 0 6px 1px rgba(0, 0, 0, 0.1), 0 0 5px rgba(0, 0, 0, 0.1), 0 5px 5px rgba(0, 0, 0, 0.25);
    -webkit-transition: background border-radius 0.75s ease-in;
    transition: background border-radius 0.75s ease-in;
    -webkit-transition: box-shadow 0.5s ease-in;
    transition: box-shadow 0.5s ease-in;
    z-index: 9999;
}

.menu-title:hover,
.open:after {
    box-shadow: 0 0 6px rgba(0, 0, 0, .1), 0 4px 6px rgba(0, 0, 0, .1);
    transform: translate3d(0, -3px, 0);
    background: -webkit-linear-gradient(top, #52C8F7 0.00%, #38C0F6 32.86%, #0AA0DB 68.93%, #098ABD 100.00%);
    background: linear-gradient(top, #F58246 0.00%, #ED7F44 32.86%, #CC7244 68.93%, #BE6E48 100.00%);
    /*box-shadow: 0 2px 1px 0 #4595f7, 0 4px 1px -1px #2578e8, 0 6px 1px -2px #1e85f7, 0 8px 1px -3px #207ce9, 0 10px 1px -4px #1c71dc, 0 12px 1px -5px #0e68dc, 0 14px 1px -6px #3f7dd0, 0 16px 1px -7px #2364bb, 0 18px 1px -8px #255ea7, 0 20px 1px -9px #023a7d, 0 6px 1px rgba(0, 0, 0, 0.1), 0 0 5px rgba(0, 0, 0, 0.1), 0 10px 20px rgba(0, 0, 0, 0.75), 0 20px 4px -6px rgba(0, 0, 0, 0.9), 0 45px 5px -5px rgba(0, 0, 0, 0.05), 0 35px 10px -5px rgba(0, 0, 0, 0.1), 0 25px 55px 5px rgba(0, 0, 0, 0.15);*/
    box-shadow: 0 2px 1px 0 #4595f7, 0 4px 1px -1px #2578e8, 0 6px 1px -2px #1e85f7, 0 6px 1px rgba(0, 0, 0, 0.1), 0 0 5px rgba(0, 0, 0, 0.1), 0 5px 5px rgba(0, 0, 0, 0.25);
    -webkit-transition: background border-radius 0.75s ease-in;
    transition: background border-radius 0.75s ease-in;
    -webkit-transition: box-shadow 0.5s ease-in;
    transition: box-shadow 0.5s ease-in;
}

