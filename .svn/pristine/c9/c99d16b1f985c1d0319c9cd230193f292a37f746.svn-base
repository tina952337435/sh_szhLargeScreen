.maplist ul li {
    cursor: pointer;
    float: left;
    width: 100%;
    min-height: 40px;
    position: relative;
    color: #2a2a2a;
    font-size: 15px;
    line-height: 20px;
    padding-top: 10px;
}

.lihover {
    background-color: #E5F2FC;
    color: #017de4 !important;
    font-weight: bold;
}

.maplist ul li div {
    margin: 10px 0px 0px 0px;
    /* width: 105px; */
    text-align: left;
    padding: 0px;
    margin-left: -5px;
}

.maplist ul li div p {
    background-color: #F9F9F9;
    color: #52565B;
    line-height: 30px;
    cursor: pointer;
    /* border-bottom: 1px solid #ddd; */
    padding-left: 50px;
    border-left: 2px solid #ebebeb;
    height: 40px;
    line-height: 40px;
    overflow: hidden;
    font-weight: normal;
}

.maplist ul li:hover {
    color: #2F94E9;
    font-weight: bold;
}

.active {
    display: none;
}

.children {
    color: #000000;
    font-size: 14px;
    display: block;
    width: 100%;
    height: 100%;
}