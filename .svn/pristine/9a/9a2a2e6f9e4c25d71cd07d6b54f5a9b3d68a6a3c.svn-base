  }
})
//刷新的方法
function refreshData() {
  var _curDataRefresh = localStorage.getItem("curDataRefresh");
  if (_curDataRefresh == true || _curDataRefresh == 'true') {
     etime.value=dayjs(new Date()).add(1, "hour").format("YYYY-MM-DD HH:mm:ss");
    Weacontent();
  } else {
    if (interVal != null && interVal != undefined) {
      clearInterval(interVal);
    }
  }
}
function Weacontent() {
  $(".light").parent().remove();
  window.loadingShow();
  
  var strParam = {};
  strParam["pid"] = pid.value;
  strParam["stime"] = stime.value;
  strParam["etime"] = etime.value; 

  apizonglan.stPptnWater(strParam).then((res) => {    
    window.loadingHide();
    const resultList =res.data;      
    strJsonData.value = resultList;
    datekeyAllJC.value=new Date();
    SWload();
  });
}
