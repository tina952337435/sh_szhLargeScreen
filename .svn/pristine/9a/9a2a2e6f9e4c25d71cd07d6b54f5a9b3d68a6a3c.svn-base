function SWload() {
  var resultList = strJsonData.value;
  var zcCount = 0,
    cjCount = 0,
    cbCount = 0,
    qcCount = 0;
  const strJson = strJsonData.value;

  // if (resultList.length > 0) {
  //   for (var num = 0; num < resultList.length; num++) {
  //     var item = resultList[num];
  //     strJson.push(item[0]);
  //   }
  // }
